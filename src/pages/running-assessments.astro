---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import { practitioners } from "../data/practitioners";
import heroImage from "../assets/services/running.jpg";
---

<ServiceLayout
  title="Running assessments"
  description="Video gait analysis, return-to-run programs and performance tuning for runners on the Sunshine Coast and Moreton Bay. Led by Joe. Physiotherapist, runner and coach of the Forward Run Club."
  eyebrow="Gait analysis · Performance · Return-to-run"
  intro="Whether you're a couch-to-5k beginner, a parkrun regular or chasing a marathon PB, our running assessments diagnose what's slowing you down (or breaking you down) and give you a clear plan to fix it."
  heroImage={heroImage}
  heroImageAlt="Forward Health physiotherapist Joe at the running assessment treadmill"
  conditions={[
    {
      heading: "Common running injuries",
      items: [
        "Runner's knee (patellofemoral pain)",
        "IT band syndrome",
        "Achilles tendinopathy",
        "Plantar fasciitis",
        "Shin splints (medial tibial stress syndrome)",
        "Hip and glute pain",
      ],
    },
    {
      heading: "Return to running",
      items: [
        "Return-to-run after baby (with our pelvic floor team)",
        "Return-to-run after injury or surgery",
        "Building back from a stress fracture",
        "Re-introducing speed and hills",
      ],
    },
    {
      heading: "Performance and longevity",
      items: [
        "Marathon and half-marathon prep",
        "Strength programming for runners",
        "Cadence and stride retraining",
        "Footwear advice and rotation strategy",
        "Training-load planning",
      ],
    },
  ]}
  whatToExpect={[
    {
      title: "Story + physical screen",
      body: "We dig into your training history, injury history, goals and any niggles. Then a movement, strength and mobility screen so we know what your body brings to the start line.",
    },
    {
      title: "Video gait analysis",
      body: "We film you running on the treadmill or outside (your choice) and break it down frame by frame, cadence, foot strike, hip drop, knee valgus, trunk position. You see exactly what we see.",
    },
    {
      title: "Plan + program",
      body: "You leave with a written running and strength plan tailored to your goal, plus 1-3 specific running cues to work on. We see you back to track progress and progress the load.",
    },
  ]}
  practitioners={[practitioners.joe]}
  locations={["Currimundi", "Sandstone Point"]}
  bookingHeading="Run with us, and get assessed by us."
  bookingBlurb="Forward Run Club meets Tuesday mornings and Friday afternoons at Aurenda Coffee Co, free, all paces welcome. Joe leads, and most of our running clients started by turning up to a run."
  faqs={[
    {
      q: "How long is a running assessment?",
      a: "60 minutes for the initial assessment, including video analysis. Follow-ups are 30 minutes.",
    },
    {
      q: "Do I need to be 'a runner' to come?",
      a: "Not at all. We see plenty of people doing their first 5k, returning after years off, or wanting to start running properly without breaking down.",
    },
    {
      q: "Can I claim through my health fund?",
      a: "Yes, running assessments are billed as physiotherapy and are claimable through every major fund.",
    },
    {
      q: "What should I wear and bring?",
      a: "Comfortable running gear and the shoes you usually run in. If you've recently changed shoes or are between pairs, bring both.",
    },
    {
      q: "Do you do prescriptions for orthotics?",
      a: "We don't dispense orthotics in-house, but we work closely with Andrew Khoury Podiatry next door at Currimundi when orthotic input is the right call.",
    },
  ]}
  related={[
    { title: "Physiotherapy", href: "/physiotherapy", blurb: "Hands-on rehab for niggles and post-injury work." },
    { title: "Forward Run Club", href: "/run-club", blurb: "Free social runs Tuesday + Friday at Aurenda Coffee Co." },
    { title: "Remedial massage", href: "/remedial-massage", blurb: "Recovery, calf and hip release for runners." },
  ]}
/>
