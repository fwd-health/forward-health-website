---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import { practitioners } from "../data/practitioners";
import heroImage from "../assets/services/remedial-massage.jpg";
---

<ServiceLayout
  title="Remedial massage"
  description="Remedial massage in Currimundi and Sandstone Point — deep tissue, lymphatic drainage, pregnancy and sports massage. Evening and weekend appointments available at Sandstone Point."
  eyebrow="Currimundi · Sandstone Point"
  intro="Hands-on therapeutic massage from experienced therapists — not a day spa. We treat the cause of your pain or tension, not just the symptoms, and we work alongside our physios when you need both."
  heroImage={heroImage}
  heroImageAlt="Forward Health remedial massage therapist working on a client"
  conditions={[
    {
      heading: "Pain and tension",
      items: [
        "Neck, shoulder and upper back tension",
        "Tension headaches",
        "Low back tightness",
        "Hip and glute trigger points",
        "TMJ and jaw tension",
      ],
    },
    {
      heading: "Sports and active",
      items: [
        "Pre- and post-event sports massage",
        "Calf and hamstring tightness",
        "IT band and quad release",
        "Recovery between training blocks",
        "Tendon and overuse niggles",
      ],
    },
    {
      heading: "Pregnancy and postnatal",
      items: [
        "Pregnancy massage (side-lying, all trimesters)",
        "Postnatal recovery and feeding-related tension",
        "Lymphatic drainage post-caesarean",
      ],
    },
    {
      heading: "Recovery and wellbeing",
      items: [
        "Manual lymphatic drainage",
        "Post-surgical scar work",
        "Stress, sleep and chronic tension",
        "Myotherapy for complex chronic pain",
      ],
    },
  ]}
  whatToExpect={[
    {
      title: "Quick health check-in",
      body: "We start with a short conversation about what you're feeling, where it's worst, and any health changes since your last visit. If something needs a physio's eyes too, we'll tell you.",
    },
    {
      title: "Targeted treatment",
      body: "Our therapists are remedial-trained, not just relaxation-trained — pressure is firm where you need it, gentler where the body needs care. You can adjust at any time.",
    },
    {
      title: "Aftercare advice",
      body: "Stretches, hydration, heat or ice — whatever helps you get the most out of your treatment. We claim through HICAPS on the spot.",
    },
  ]}
  practitioners={[
    practitioners.tara,
    practitioners.carly,
    practitioners.catalina,
  ]}
  locations={["Currimundi", "Sandstone Point"]}
  bookingHeading="Evening and weekend appointments at Sandstone Point."
  bookingBlurb="The only allied health clinic in the Sandstone Point / Bribie Island area offering remedial massage outside business hours. Book online or call us."
  faqs={[
    {
      q: "Can I claim massage through my private health fund?",
      a: "Yes, if you have remedial massage cover. Our therapists are all qualified remedial massage therapists registered with the major funds, and we process HICAPS on the spot.",
    },
    {
      q: "What's the difference between remedial massage and myotherapy?",
      a: "Myotherapy is a deeper specialisation in chronic and complex muscular pain — assessment-led, often using techniques like dry needling, cupping and joint mobilisation alongside soft tissue work. Tara is our advanced-diploma myotherapist for these cases.",
    },
    {
      q: "Is pregnancy massage safe in the first trimester?",
      a: "Yes — pregnancy massage is safe in all trimesters when delivered by a trained therapist. We use side-lying positioning from the second trimester onwards and adapt pressure for your stage.",
    },
    {
      q: "How often should I have remedial massage?",
      a: "It varies. For an acute issue, one or two sessions close together usually settles things. For maintenance, most regular clients come every 3–6 weeks.",
    },
  ]}
  related={[
    { title: "Physiotherapy", href: "/physiotherapy", blurb: "When the cause of pain needs hands-on physio care too." },
    { title: "Pelvic floor physio", href: "/pelvic-floor-physio", blurb: "Pregnancy and postnatal physio." },
    { title: "Clinical pilates", href: "/clinical-pilates", blurb: "Build the strength behind the relief." },
  ]}
/>
