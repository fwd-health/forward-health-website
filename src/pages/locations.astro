---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import BookingBlock from "../components/BookingBlock.astro";
import sandstoneImage from "../assets/locations/sandstone-point.jpg";

const clinics = [
  {
    name: "Currimundi",
    region: "Sunshine Coast",
    address: "Shop 3 / 768 Nicklin Way, Currimundi QLD 4551",
    blurb:
      "Our Sunshine Coast clinic, co-located with Currimundi Family Doctors, Andrew Khoury Podiatry and a small constellation of allied health practitioners. Easy parking, ground-floor access, the largest team across our two clinics.",
    href: "/locations/currimundi",
    image: null,
  },
  {
    name: "Sandstone Point",
    region: "Moreton Bay · Just over the bridge from Bribie Island",
    address: "Shop 3 / 208 Bestmann Road East, Sandstone Point QLD 4511",
    blurb:
      "Our Moreton Bay clinic, purpose-built reformer pilates studio, dedicated treatment rooms, and the only allied health space in the area offering remedial massage on evenings and weekends.",
    href: "/locations/sandstone-point",
    image: sandstoneImage,
  },
];
---

<Layout
  title="Our clinics, Forward Health"
  description="Forward Health has two clinics: Currimundi on the Sunshine Coast, and Sandstone Point in Moreton Bay (five minutes over the bridge from Bribie Island)."
>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">Our clinics</p>
        <h1 class="text-charcoal">Two locations, one team.</h1>
        <p class="mt-6 text-lg text-stone leading-relaxed">
          Most of our practitioners work across both clinics, so you can stick with your favourite
          physio even if you start at the other location. Same notes, same plan, same care.
        </p>
      </div>
    </div>
  </section>

  <!-- Clinics grid -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="grid lg:grid-cols-2 gap-10">
      {clinics.map((c) => (
        <a
          href={c.href}
          class="group block rounded-3xl overflow-hidden border border-sage-100 bg-white hover:border-sage-300 hover:shadow-md transition-all"
        >
          {c.image ? (
            <Image
              src={c.image}
              alt={`Forward Health ${c.name} clinic`}
              width={1200}
              height={800}
              class="aspect-[3/2] object-cover w-full group-hover:scale-[1.02] transition-transform duration-500"
            />
          ) : (
            <div class="aspect-[3/2] bg-sage-100 flex items-center justify-center text-sage-600/60 text-sm">
              [ {c.name} clinic photo ]
            </div>
          )}
          <div class="p-8 lg:p-10">
            <p class="text-xs uppercase tracking-[0.18em] text-tan-600">{c.region}</p>
            <h2 class="mt-2 text-3xl text-charcoal group-hover:text-sage-600 transition-colors">{c.name}</h2>
            <p class="mt-3 text-sm text-stone">{c.address}</p>
            <p class="mt-5 text-stone leading-relaxed">{c.blurb}</p>
            <span class="mt-6 inline-block text-sm font-semibold text-sage-600 group-hover:translate-x-0.5 transition-transform">
              See clinic details →
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <BookingBlock variant="sage" />
</Layout>
