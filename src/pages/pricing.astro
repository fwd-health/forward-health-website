---
import Layout from "../layouts/Layout.astro";
import BookingBlock from "../components/BookingBlock.astro";

const sections = [
  {
    title: "Physiotherapy",
    items: [
      { label: "Initial consultation", duration: "60 min", price: "$135" },
      { label: "Standard appointment", duration: "30 min", price: "$110" },
      { label: "Extended appointment", duration: "45 min", price: "$165" },
      { label: "Extended appointment", duration: "60 min", price: "$220" },
    ],
  },
  {
    title: "Pelvic floor physio",
    items: [
      { label: "Initial consultation", duration: "60 min", price: "$180" },
      { label: "Follow-up appointment", duration: "45 min", price: "$160" },
      { label: "Pessary fitting (excludes pessary cost)", duration: "20 min", price: "$95" },
    ],
  },
  {
    title: "Vertigo & vestibular physio",
    items: [
      { label: "Initial consultation", duration: "45 min", price: "$160" },
      { label: "Follow-up appointment", duration: "30 min", price: "$130" },
    ],
  },
  {
    title: "Running assessments",
    items: [
      { label: "Initial running assessment", duration: "60 min", price: "$220" },
      { label: "Follow-up running session", duration: "45 min", price: "$180" },
    ],
  },
  {
    title: "Paediatric & home visit physio",
    items: [
      { label: "Paediatric physio", duration: "varies", price: "Contact us" },
      { label: "Home visit physio (plus travel charge)", duration: "varies", price: "Contact us" },
    ],
  },
  {
    title: "Remedial massage",
    items: [
      { label: "Remedial massage", duration: "30 min", price: "$75" },
      { label: "Remedial massage", duration: "45 min", price: "$90" },
      { label: "Remedial massage", duration: "60 min", price: "$125" },
    ],
  },
  {
    title: "Clinical pilates",
    items: [
      { label: "Initial 1-on-1 assessment", duration: "60 min", price: "$135" },
      { label: "3-class pack", duration: "-", price: "$114", note: "$38 / class" },
      { label: "6-class pack", duration: "-", price: "$216", note: "$36 / class" },
      { label: "12-class pack", duration: "-", price: "$408", note: "$34 / class" },
      { label: "24-class pack", duration: "-", price: "$768", note: "$32 / class" },
    ],
  },
  {
    title: "Strength & Balance classes",
    items: [
      { label: "Single class (drop-in or by package)", duration: "-", price: "$25 / session" },
    ],
  },
  {
    title: "Hydrotherapy classes",
    items: [
      { label: "Casual class", duration: "-", price: "$25", note: "Excluding pool entry fee" },
      { label: "5 class pack", duration: "-", price: "$100", note: "$20 / class, excluding pool entry fee" },
      { label: "10 class pack", duration: "-", price: "$180", note: "$18 / class, excluding pool entry fee" },
    ],
  },
];

const healthFundCodes = [
  { service: "Initial physiotherapy consultation", code: "500" },
  { service: "Subsequent physiotherapy consultation", code: "505" },
  { service: "Pelvic floor / women's health consultation", code: "593" },
  { service: "Vertigo & vestibular physio", code: "582" },
  { service: "Running assessment", code: "506" },
  { service: "Clinical pilates class (group)", code: "560" },
  { service: "Strength & Balance class (group)", code: "560" },
  { service: "Hydrotherapy class (group)", code: "560" },
  { service: "Remedial massage (30 / 45 / 60 min)", code: "102 / 103 / 105 (varies by fund)" },
];
---

<Layout
  title="Pricing, Forward Health"
  description="Forward Health pricing for physiotherapy, pelvic floor physio, vertigo physio, running assessments, clinical pilates, strength & balance, hydrotherapy, paediatrics and remedial massage. HCF and Medibank preferred provider, HICAPS on-the-spot claiming."
>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">Pricing</p>
        <h1 class="text-charcoal">Honest pricing, on-the-spot claiming.</h1>
        <p class="mt-6 text-lg text-stone leading-relaxed">
          Every price below is the fee you'd pay before health-fund rebate. We process HICAPS
          claims on the spot for every major fund, so most clients pay only the difference between
          the fee and their rebate.
        </p>
      </div>
    </div>
  </section>

  <!-- Pricing tables -->
  <section class="max-w-5xl mx-auto px-5 lg:px-8 py-16 lg:py-20 space-y-10">
    {sections.map((s) => (
      <div class="rounded-3xl border border-sage-100 bg-white overflow-hidden">
        <div class="px-6 lg:px-8 py-5 bg-cream-50 border-b border-sage-100">
          <h2 class="font-display text-xl lg:text-2xl text-charcoal">{s.title}</h2>
        </div>
        <ul class="divide-y divide-sage-100">
          {s.items.map((it) => (
            <li class="px-6 lg:px-8 py-4 flex items-center justify-between gap-4">
              <div>
                <p class="text-charcoal font-medium">{it.label}</p>
                {it.duration && it.duration !== "-" && (
                  <p class="text-xs text-stone uppercase tracking-[0.14em] mt-0.5">{it.duration}</p>
                )}
                {it.note && (
                  <p class="text-xs text-stone mt-0.5">{it.note}</p>
                )}
              </div>
              <p class="text-charcoal font-display text-lg shrink-0">{it.price}</p>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </section>

  <!-- Health fund codes -->
  <section class="bg-cream-50 py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-10">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Health fund codes</p>
        <h2 class="text-charcoal text-2xl lg:text-3xl">Item codes for your fund.</h2>
        <p class="mt-4 text-stone leading-relaxed">
          We process HICAPS claims on the spot. If your fund requires the item code in advance to
          quote a rebate, the typical codes for each of our services are below. Codes occasionally
          vary by fund, so if your fund quotes back something different, give us a call and we'll
          confirm.
        </p>
      </div>
      <div class="rounded-3xl border border-sage-100 bg-white overflow-hidden">
        <ul class="divide-y divide-sage-100">
          {healthFundCodes.map((c) => (
            <li class="px-6 lg:px-8 py-4 flex items-center justify-between gap-4">
              <p class="text-charcoal">{c.service}</p>
              <p class="text-charcoal font-display text-lg shrink-0">{c.code}</p>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- Funding & rebates -->
  <section class="py-16 lg:py-20">
    <div class="max-w-5xl mx-auto px-5 lg:px-8 grid md:grid-cols-2 gap-10">
      <div>
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Health funds</p>
        <h2 class="text-charcoal text-2xl lg:text-3xl">Claim on the spot.</h2>
        <p class="mt-4 text-stone leading-relaxed">
          HICAPS for every major Australian health fund. <strong>HCF preferred provider</strong> for all services
          and <strong>Medibank preferred provider</strong> for physiotherapy, meaning the rebate is higher.
        </p>
      </div>
      <div>
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Discounts & subsidised streams</p>
        <ul class="space-y-3 text-stone leading-relaxed">
          <li class="flex gap-3">
            <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span>
            <span><strong>$10 discount</strong> for concession, pension and full-time student cardholders.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span>
            <span><strong>GP CCMP</strong> (formerly TCA, EPC, or commonly known as Medicare referrals), 5 sessions/year via your GP, small gap fee applies.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span>
            <span><strong>DVA Gold and White Cards</strong>, bulk billed where the condition is on your card. GP referral required.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span>
            <span><strong>WorkCover</strong>, $100 deposit required at booking, refunded at the end of your claim. Valid referral needed.</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span>
            <span><strong>NDIS</strong>, plan-managed and self-managed only. Not a registered provider.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Cancellation note -->
  <section class="max-w-5xl mx-auto px-5 lg:px-8 pb-16">
    <div class="rounded-3xl bg-tan-100/40 border border-tan-200 p-8 text-stone">
      <p class="text-sm font-semibold text-charcoal mb-3 uppercase tracking-[0.14em]">Late-cancellation policy</p>
      <p class="text-sm leading-relaxed">
        We have a 24-hour cancellation policy.
      </p>
      <ul class="mt-3 space-y-2 text-sm leading-relaxed">
        <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span><span><strong class="text-charcoal">Private-paying patients:</strong> $50 late-cancellation fee.</span></li>
        <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span><span><strong class="text-charcoal">NDIS, DVA and Home Care Package patients:</strong> the late-cancellation fee is billed directly to the service provider.</span></li>
        <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span><span><strong class="text-charcoal">WorkCover patients:</strong> a $100 deposit is required at booking, refunded at the end of your claim.</span></li>
        <li class="flex gap-3"><span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full bg-sage-500"></span><span><strong class="text-charcoal">Pilates / S&amp;B / Hydrotherapy classes:</strong> the class is billed in full from your package.</span></li>
      </ul>
      <p class="mt-4 text-sm">
        Life happens, let us know as early as you can.
        <a href="/policies" class="text-sage-600 underline">Full policies →</a>
      </p>
    </div>
  </section>

  <BookingBlock variant="sage" />
</Layout>
