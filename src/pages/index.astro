---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import heroImg from "../assets/hero-clinical-pilates.jpg";
import mbHeroImg from "../assets/hero-pregnancy-physio.jpg";
import runClubPoster from "../assets/run-club/run-club-poster.jpg";
import mbLogo from "../assets/mums-and-bubs/logo.svg";

import physiotherapyImg from "../assets/services/physiotherapy.jpg";
import pelvicFloorImg from "../assets/services/pelvic-floor-card.jpg";
import remedialMassageImg from "../assets/services/remedial-massage.jpg";
import runningImg from "../assets/services/running.jpg";
import vertigoImg from "../assets/services/vertigo.jpg";
import paediatricImg from "../assets/services/paediatric-card.jpg";
import clinicalPilatesImg from "../assets/services/clinical-pilates.jpg";
import homeVisitsImg from "../assets/services/home-visits.jpg";

const heroServices = [
  {
    title: "Physiotherapy",
    blurb: "General musculoskeletal, sports and post-surgical rehab. Back pain, neck, shoulders, knees, ankles.",
    href: "/physiotherapy",
    image: physiotherapyImg,
    objectPosition: "center",
  },
  {
    title: "Pelvic floor physio",
    blurb: "Pregnancy, postnatal recovery, pelvic pain, prolapse and pessary fittings.",
    href: "/pelvic-floor-physio",
    image: pelvicFloorImg,
    objectPosition: "center",
  },
  {
    title: "Remedial massage",
    blurb: "Deep tissue, relaxation, lymphatic and pregnancy massage. Available at both Currimundi and Sandstone Point.",
    href: "/remedial-massage",
    image: remedialMassageImg,
    objectPosition: "center",
  },
  {
    title: "Running assessments",
    blurb: "Video gait analysis, return-to-run plans and performance tuning for runners of all levels.",
    href: "/running-assessments",
    image: runningImg,
    objectPosition: "center",
  },
  {
    title: "Vertigo & vestibular physio",
    blurb: "Expert care for BPPV, vestibular migraine, post-concussion and balance disorders.",
    href: "/vertigo-vestibular-physio",
    image: vertigoImg,
    objectPosition: "center",
  },
  {
    title: "Paediatric physiotherapy",
    blurb: "From developmental milestones to adolescent sports injuries, both ends of paeds.",
    href: "/paediatric-physio",
    image: paediatricImg,
    objectPosition: "center",
  },
  {
    title: "Clinical pilates",
    blurb: "Mat, reformer and wundachair classes. Max 4 at Currimundi, max 6 at Sandstone Point. Physio-led, every class.",
    href: "/clinical-pilates",
    image: clinicalPilatesImg,
    objectPosition: "center",
  },
  {
    title: "Home visit physiotherapy",
    blurb: "For patients who can't get to the clinic. Limited mobility, post-hospital discharge, after surgery, or anyone who can't drive in.",
    href: "/home-visits",
    image: homeVisitsImg,
    objectPosition: "center",
  },
];

const locations = [
  {
    name: "Currimundi",
    region: "Sunshine Coast",
    address: "Shop 3 / 768 Nicklin Way, Currimundi QLD 4551",
    href: "/locations/currimundi",
  },
  {
    name: "Sandstone Point",
    region: "Moreton Bay · Bribie Island",
    address: "Shop 3 / 208 Bestmann Road East, Sandstone Point QLD 4511",
    href: "/locations/sandstone-point",
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="relative bg-sage-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-28">
      <!-- Heading + image side-by-side. Image dominant on mobile (col-span-7) so it's ~2.5x larger area than before -->
      <div class="grid grid-cols-12 gap-3 lg:gap-10 items-center">
        <div class="col-span-5 lg:col-span-7">
          <p class="text-[0.65rem] sm:text-xs lg:text-sm uppercase tracking-[0.14em] lg:tracking-[0.18em] text-tan-600 mb-2 lg:mb-4 leading-tight">
            Currimundi · Sandstone Point · Bribie Island
          </p>
          <h1 class="text-charcoal" style="font-size: clamp(1.4rem, 5.5vw, 3.75rem); line-height: 1.05;">
            Feel better.<br />
            Live better.<br />
            <span class="text-sage-600">Move forward.</span>
          </h1>
        </div>

        <div class="col-span-7 lg:col-span-5">
          <Image
            src={heroImg}
            alt="Forward Health clinical pilates session, a patient on the wundachair in our Sandstone Point studio"
            width={900}
            height={1125}
            class="aspect-[3/4] lg:aspect-[4/5] rounded-2xl lg:rounded-3xl object-cover w-full"
            loading="eager"
          />
        </div>
      </div>

      <!-- Lead paragraph + CTAs full-width below -->
      <div class="mt-6 lg:mt-8 lg:max-w-2xl">
        <p class="text-base lg:text-lg leading-relaxed text-stone">
          Personalised physiotherapy, pelvic floor care, vertigo treatment, remedial
          massage, and clinical pilates, across two clinics serving the Sunshine
          Coast and Moreton Bay.
        </p>
        <div class="mt-5 lg:mt-7 flex flex-wrap gap-3">
          <a
            href="https://forward-health-group.au2.cliniko.com/bookings" target="_blank" rel="noopener"
            class="inline-flex items-center rounded-full bg-sage-600 px-6 lg:px-7 py-3 lg:py-3.5 text-sm lg:text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Book online
          </a>
          <a
            href="tel:0420522558"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-6 lg:px-7 py-3 lg:py-3.5 text-sm lg:text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            Call 0420 522 558
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero services -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">What we do</p>
      <h2>Specialised care alongside everyday physio.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        Every patient is matched with the practitioner whose niche fits their condition,
        not just whoever's free. That's how we get better outcomes, faster.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5">
      {heroServices.map((s) => (
        <a
          href={s.href}
          class="group block rounded-2xl border border-sage-100 bg-white hover:border-sage-300 hover:shadow-sm transition-all overflow-hidden"
        >
          <div class="aspect-[4/3] overflow-hidden bg-sage-100">
            <Image
              src={s.image}
              alt={s.title}
              width={600}
              height={450}
              class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
              style={`object-position: ${s.objectPosition};`}
            />
          </div>
          <div class="p-5 lg:p-6">
            <h3 class="text-charcoal group-hover:text-sage-600 transition-colors text-xl">{s.title}</h3>
            <p class="mt-2 text-sm text-stone leading-relaxed">{s.blurb}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-sage-600">
              Learn more →
            </span>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- Locations -->
  <section class="bg-cream-50 py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Our clinics</p>
        <h2>Two locations, one team.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {locations.map((loc) => (
          <a
            href={loc.href}
            class="block p-8 rounded-2xl bg-white border border-sage-100 hover:border-sage-300 transition-all"
          >
            <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-2">{loc.region}</p>
            <h3 class="text-2xl text-charcoal">{loc.name}</h3>
            <p class="mt-3 text-stone leading-relaxed">{loc.address}</p>
            <span class="mt-5 inline-block text-sm font-semibold text-sage-600">
              See clinic details →
            </span>
          </a>
        ))}
      </div>

      <p class="mt-10 text-sm text-stone text-center max-w-4xl mx-auto leading-relaxed">
        Serving Currimundi, Caloundra, Moffat Beach, Dicky Beach, Little Mountain, Aroona, Meridan
        Plains, Warana, Bokarina, Wurtulla, Buddina, Battery Hill, Birtinya, Golden Beach, Kings Beach,
        Shelly Beach, Pelican Waters, Sandstone Point, Bribie Island (Bellara, Bongaree, Banksia Beach,
        Woorim) and surrounding suburbs.
      </p>
    </div>
  </section>

  <!-- Mums & Bubs teaser, M&B themed -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20">
    <div class="rounded-3xl p-10 lg:p-16 grid lg:grid-cols-2 gap-10 items-center"
         style="background-color: var(--color-mb-cream); color: var(--color-mb-ink); border: 1px solid var(--color-mb-rule);">
      <div>
        <div class="flex items-center gap-3 mb-5">
          <img src={mbLogo.src} alt="" class="w-36 h-36" />
          <p class="text-xs uppercase tracking-[0.18em] font-semibold" style="color: var(--color-mb-terracotta-dark);">Mums &amp; Bubs Physio</p>
        </div>
        <h2 style="font-family: var(--font-mb-serif); font-weight: 400; font-size: clamp(1.85rem, 3.5vw, 2.65rem); line-height: 1.15;">
          From bump to bub, <em style="font-style: italic; color: var(--color-mb-terracotta);">under one roof</em>.
        </h2>
        <p class="mt-5 leading-relaxed" style="color: var(--color-mb-muted);">
          The only physio team across the Sunshine Coast and Moreton Bay following you and your baby
          through pregnancy, birth recovery and developmental milestones. Pelvic floor and paediatric
          physio by the same trusted clinicians.
        </p>
        <a
          href="/mums-and-bubs"
          class="mt-7 inline-flex items-center rounded-full px-7 py-3.5 text-sm font-semibold transition-colors"
          style="background-color: var(--color-mb-terracotta); color: white;"
          onmouseover="this.style.backgroundColor='var(--color-mb-terracotta-dark)'"
          onmouseout="this.style.backgroundColor='var(--color-mb-terracotta)'"
        >
          Mums &amp; Bubs at Forward Health →
        </a>
      </div>
      <div>
        <Image
          src={mbHeroImg}
          alt="Forward Health pelvic floor physiotherapist with a pregnant patient"
          width={900}
          height={675}
          class="aspect-[4/3] rounded-2xl object-cover w-full"
        />
      </div>
    </div>
  </section>

  <!-- Run Club teaser, RC themed -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-20">
    <div class="rounded-3xl p-10 lg:p-16 grid lg:grid-cols-12 gap-10 items-center"
         style="background-color: var(--color-rc-cream); color: var(--color-rc-ink); border: 1px solid var(--color-rc-rule);">
      <div class="lg:col-span-7">
        <p class="text-xs uppercase tracking-[0.18em] font-semibold mb-5" style="color: var(--color-rc-rust-dark);">@fwdrunclub · Kings Beach</p>
        <h2 style="color: var(--color-rc-ink); font-family: var(--font-display); font-weight: 600; font-size: clamp(1.85rem, 3.5vw, 2.65rem); line-height: 1.15;">
          All for run. <em style="font-style: italic; color: var(--color-rc-rust);">Run for all.</em>
        </h2>
        <p class="mt-5 leading-relaxed" style="color: var(--color-rc-muted);">
          A free, easygoing running community on the Sunshine Coast. Sunrise runs every Tuesday at 5:30 am
          + monthly Friday afternoon socials at <strong>Aurenda Coffee Co, Kings Beach</strong>. Beginner
          pace welcome. Marathon pace welcome. Walking-and-chatting pace, also welcome.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="https://www.instagram.com/fwdrunclub/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-full px-7 py-3.5 text-sm font-semibold transition-colors"
            style="background-color: var(--color-rc-rust); color: var(--color-rc-cream);"
            onmouseover="this.style.backgroundColor='var(--color-rc-rust-dark)'"
            onmouseout="this.style.backgroundColor='var(--color-rc-rust)'"
          >
            Follow @fwdrunclub
          </a>
          <a
            href="/run-club"
            class="inline-flex items-center rounded-full px-7 py-3.5 text-sm font-semibold transition-colors"
            style="background-color: white; border: 1px solid var(--color-rc-rule); color: var(--color-rc-ink);"
            onmouseover="this.style.borderColor='var(--color-rc-rust)'"
            onmouseout="this.style.borderColor='var(--color-rc-rule)'"
          >
            Run with us →
          </a>
        </div>
      </div>
      <div class="lg:col-span-5">
        <Image
          src={runClubPoster}
          alt="Forward Run Club mascot poster, corgi runner with coffee, Aurenda Coffee Co Kings Beach"
          width={900}
          height={1200}
          class="aspect-[3/4] rounded-2xl object-cover w-full max-w-sm mx-auto"
        />
      </div>
    </div>
  </section>
</Layout>
