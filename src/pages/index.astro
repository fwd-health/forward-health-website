---
import Layout from "../layouts/Layout.astro";

const heroServices = [
  {
    title: "Vertigo & vestibular physio",
    blurb: "Expert care for BPPV, vestibular migraine, post-concussion and balance disorders.",
    href: "/vertigo-vestibular-physio",
  },
  {
    title: "Pelvic floor & women's health",
    blurb: "Pregnancy, postnatal recovery, pelvic pain, prolapse and pessary fittings.",
    href: "/pelvic-floor-physio",
  },
  {
    title: "Paediatric physiotherapy",
    blurb: "From developmental milestones to adolescent sports injuries — both ends of paeds.",
    href: "/paediatric-physio",
  },
  {
    title: "Running assessments",
    blurb: "Video gait analysis, return-to-run plans and performance tuning for everyday runners.",
    href: "/running-assessments",
  },
  {
    title: "Remedial massage",
    blurb: "Deep tissue, lymphatic, pregnancy massage. Evening + weekend at Sandstone Point.",
    href: "/remedial-massage",
  },
  {
    title: "Clinical pilates",
    blurb: "Reformer-based, max 6 per class. Rehab-led, not fitness-led.",
    href: "/clinical-pilates",
  },
  {
    title: "Home visit physiotherapy",
    blurb: "NDIS (plan / self-managed), Home Care Packages, Remedy Health post-discharge, DVA.",
    href: "/home-visits",
  },
];

const locations = [
  {
    name: "Currimundi",
    region: "Sunshine Coast",
    address: "Shop 3 / 768 Nicklin Way, Currimundi QLD 4551",
    href: "/locations/currimundi",
  },
  {
    name: "Sandstone Point",
    region: "Moreton Bay · Bribie Island",
    address: "Shop 3 / 208 Bestmann Road East, Sandstone Point QLD 4511",
    href: "/locations/sandstone-point",
  },
];
---

<Layout>
  <!-- Hero -->
  <section class="relative bg-sage-50 overflow-hidden">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-20 lg:py-28 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">
          Currimundi · Sandstone Point · Bribie Island
        </p>
        <h1 class="text-charcoal">
          Move better.<br />
          Feel more confident in your body.<br />
          <span class="text-sage-600">Get back to living fully.</span>
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-stone max-w-xl">
          Personalised physiotherapy, pelvic floor care, vertigo treatment, remedial
          massage, and clinical pilates — across two clinics serving the Sunshine
          Coast and Moreton Bay.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="#book"
            class="inline-flex items-center rounded-full bg-sage-600 px-7 py-3.5 text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Book online
          </a>
          <a
            href="tel:0420522558"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-7 py-3.5 text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            Call 0420 522 558
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="aspect-[4/5] rounded-3xl bg-sage-200/60 border border-sage-200 flex items-center justify-center text-sage-600/60 text-sm">
          [ hero video / photo placeholder ]
        </div>
      </div>
    </div>
  </section>

  <!-- Hero services -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">What we do</p>
      <h2>Specialised care alongside everyday physio.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        Every patient is matched with the practitioner whose niche fits their condition —
        not just whoever's free. That's how we get better outcomes, faster.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {heroServices.map((s) => (
        <a
          href={s.href}
          class="group p-7 rounded-2xl border border-sage-100 bg-white hover:border-sage-300 hover:shadow-sm transition-all"
        >
          <h3 class="text-charcoal group-hover:text-sage-600 transition-colors">{s.title}</h3>
          <p class="mt-2 text-sm text-stone leading-relaxed">{s.blurb}</p>
          <span class="mt-4 inline-block text-sm font-semibold text-sage-600">
            Learn more →
          </span>
        </a>
      ))}
    </div>
  </section>

  <!-- Locations -->
  <section class="bg-cream-50 py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Our clinics</p>
        <h2>Two locations, one team.</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-6">
        {locations.map((loc) => (
          <a
            href={loc.href}
            class="block p-8 rounded-2xl bg-white border border-sage-100 hover:border-sage-300 transition-all"
          >
            <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-2">{loc.region}</p>
            <h3 class="text-2xl text-charcoal">{loc.name}</h3>
            <p class="mt-3 text-stone leading-relaxed">{loc.address}</p>
            <span class="mt-5 inline-block text-sm font-semibold text-sage-600">
              See clinic details →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Mums & Bubs teaser -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-20">
    <div class="rounded-3xl bg-sage-700 text-cream-100 p-10 lg:p-16 grid lg:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-sm uppercase tracking-[0.18em] text-tan-200 mb-3">Mums & Bubs</p>
        <h2 class="text-cream-50">From bump to bub — under one roof.</h2>
        <p class="mt-5 text-cream-100/90 leading-relaxed">
          The only physio team across the Sunshine Coast and Moreton Bay following you
          and your baby through pregnancy, birth recovery and developmental milestones —
          pelvic floor and paediatric physio by the same trusted clinicians.
        </p>
        <a
          href="/mums-and-bubs"
          class="mt-7 inline-flex items-center rounded-full bg-cream-50 px-7 py-3.5 text-sm font-semibold text-sage-700 hover:bg-tan-100 transition-colors"
        >
          Mums & Bubs at Forward Health →
        </a>
      </div>
      <div class="aspect-[4/3] rounded-2xl bg-sage-600/40 border border-sage-500/40 flex items-center justify-center text-cream-100/60 text-sm">
        [ pregnancy / postnatal imagery placeholder ]
      </div>
    </div>
  </section>
</Layout>
