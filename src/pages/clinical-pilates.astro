---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import { practitioners } from "../data/practitioners";
import heroImage from "../assets/services/clinical-pilates.jpg";
---

<ServiceLayout
  title="Clinical pilates"
  description="Reformer-based clinical pilates across Sandstone Point and Currimundi — small-group classes (max 6) at Sandstone Point, 1:1 reformer sessions at Currimundi. Physio-led, rehab-first, not fitness-first."
  eyebrow="Reformer · Physio-led · Rehab-first"
  intro="Clinical pilates is rehab dressed up as exercise. Every session — class or 1:1 — is run by a physiotherapist, and your program is built specifically for your body. No generic flows, no following the strongest person in the room."
  heroImage={heroImage}
  heroImageAlt="Forward Health clinical pilates on the reformer with a physiotherapist"
  conditions={[
    {
      heading: "Common reasons people start",
      items: [
        "Persistent low back or hip pain",
        "Postnatal recovery (cleared by your physio)",
        "Post-injury or post-surgical rehab",
        "Hypermobility and joint instability",
        "Osteoporosis and bone-density support",
        "Building consistent strength habits",
      ],
    },
    {
      heading: "Two formats — pick what suits",
      items: [
        "Small-group classes at Sandstone Point (max 6 on reformers)",
        "1:1 reformer sessions at Currimundi (purely individual)",
        "Programs are personalised regardless of format",
        "Health-fund claimable as physio either way",
        "Switch between formats if your needs change",
      ],
    },
    {
      heading: "Who shouldn't start with us",
      items: [
        "Total beginners just looking for a workout — we're rehab-led",
        "People wanting a high-impact cardio session",
        "Acute, undiagnosed pain — see one of our physios first",
      ],
    },
  ]}
  whatToExpect={[
    {
      title: "1:1 assessment first",
      body: "Before you join either format, we book you in for a 1:1 with one of our physios. They build your individual program based on your body, goals and any injuries — and recommend whether 1:1 or small-group will get you there fastest.",
    },
    {
      title: "Your format, your program",
      body: "At Sandstone Point, you follow your program in a small group on the reformer — up to five other people are in the room, but no one's doing exactly what you're doing. At Currimundi, you work 1:1 with your physio on the reformer for the entire session.",
    },
    {
      title: "Reviewed every 6–8 weeks",
      body: "We update your program as you get stronger so the work stays meaningful. If something's painful or unclear, you tell us immediately — that's the whole point of having a physio in the room.",
    },
  ]}
  practitioners={[
    practitioners.brianna,
    practitioners.holly,
    practitioners.steph,
    practitioners.joe,
  ]}
  locations={["Currimundi", "Sandstone Point"]}
  bookingHeading="Two clinics, two formats."
  bookingBlurb="Group classes (max 6) run from our reformer studio at Sandstone Point. Currimundi runs 1:1 reformer sessions only — no group classes there. Easiest way to start is a 1:1 assessment, and we'll match you to the right format and clinician."
  faqs={[
    {
      q: "What's the difference between the two locations?",
      a: "Sandstone Point has a dedicated reformer studio and runs small-group classes (max 6 on reformers). Currimundi runs 1:1 reformer sessions only — every appointment is one-on-one with your physio. The clinical programming is the same; only the format differs.",
    },
    {
      q: "Which should I pick — 1:1 or class?",
      a: "1:1 if you want maximum personal attention, are early in rehab, or have something complex going on. Small-group classes once you're stable, want the routine, and prefer the slightly lower price point per session. Plenty of clients move between both as their needs change.",
    },
    {
      q: "Can I claim pilates through my health fund?",
      a: "Yes — clinical pilates is delivered by a physiotherapist (1:1 or class) and is claimable under physio cover. We're HCF preferred and Medibank preferred for physio. HICAPS available for everyone else.",
    },
    {
      q: "How many sessions per week?",
      a: "Most clients do 1–2 sessions a week. Two is where we see the strongest changes in strength and confidence over the first 8–12 weeks.",
    },
    {
      q: "I'm 8 weeks postnatal — can I start?",
      a: "Pop in for a postnatal physio assessment first. If you've had a straightforward recovery, you'll likely be cleared. If you need to build groundwork on diastasis or pelvic floor first, we'll do that and bring you to reformer when you're ready.",
    },
    {
      q: "What if I miss a class at Sandstone Point?",
      a: "We have a fair make-up policy — let us know in advance and we'll find another class that suits you within the same fortnight where possible.",
    },
  ]}
  related={[
    { title: "Pelvic floor physio", href: "/pelvic-floor-physio", blurb: "Postnatal clearance and pelvic floor screening." },
    { title: "Physiotherapy", href: "/physiotherapy", blurb: "Hands-on rehab for what reformer alone won't fix." },
    { title: "Running assessments", href: "/running-assessments", blurb: "Strength + running prescribed together." },
  ]}
/>
