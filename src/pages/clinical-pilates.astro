---
import ServiceLayout from "../layouts/ServiceLayout.astro";
import { practitioners } from "../data/practitioners";
import heroImage from "../assets/services/clinical-pilates.jpg";

const days = ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"];

const currimundiClasses: Record<string, { time: string; lead: string }[]> = {
  Monday: [{ time: "10:00 am", lead: "Brianna" }],
  Tuesday: [{ time: "2:00 pm", lead: "Steph" }],
  Wednesday: [{ time: "8:00 am", lead: "Brianna" }],
  Thursday: [],
  Friday: [{ time: "8:00 am", lead: "Joe" }],
};

const sandstoneClasses: Record<string, { time: string; lead: string }[]> = {
  Monday: [{ time: "3:00 pm", lead: "Steph" }],
  Tuesday: [
    { time: "7:00 am", lead: "Bri" },
    { time: "8:30 am", lead: "Bri" },
  ],
  Wednesday: [
    { time: "9:00 am", lead: "Holly" },
    { time: "4:30 pm", lead: "Joe" },
  ],
  Thursday: [
    { time: "6:00 am", lead: "Joe" },
    { time: "8:00 am", lead: "Joe" },
    { time: "3:00 pm", lead: "Bri" },
  ],
  Friday: [
    { time: "8:00 am", lead: "Holly" },
    { time: "3:00 pm", lead: "Holly" },
  ],
};

const packages = [
  { name: "3 class pack", price: "$114", perClass: "$38/class" },
  { name: "6 class pack", price: "$216", perClass: "$36/class" },
  { name: "12 class pack", price: "$408", perClass: "$34/class" },
  { name: "24 class pack", price: "$768", perClass: "$32/class" },
];
---

<ServiceLayout
  title="Clinical pilates"
  description="Physio-led clinical pilates at Forward Health Currimundi and Sandstone Point. Small-group, individualised mat, reformer and wundachair classes for safe, tailored exercise."
  eyebrow="Mat · Reformer · Wundachair · Physio-led"
  intro="Small-group classes, all physio-led, so your exercises are safe and individualised to you. After a 1:1 assessment, your physio modifies each exercise during class to suit you, your body and any injury you're working through."
  heroImage={heroImage}
  heroImageAlt="Forward Health clinical pilates class with reformer and wundachair work"
  conditions={[
    {
      heading: "Common reasons people start",
      items: [
        "Persistent low back or hip pain",
        "Postnatal recovery (cleared by your physio)",
        "Post-injury or post-surgical rehab",
        "Hypermobility and joint instability",
        "Osteoporosis and bone-density support",
        "Building consistent strength habits",
      ],
    },
    {
      heading: "Classes at both clinics",
      items: [
        "Currimundi: mat, reformer and wundachair, max 4 per class",
        "Sandstone Point: mat, reformer and wundachair, max 6 per class",
        "Every exercise modified to you, by your physio, during class",
        "A physiotherapist in the room every session",
        "Health-fund claimable as physio either way",
        "Switch clinics or class times whenever your schedule changes",
      ],
    },
  ]}
  whatToExpect={[
    {
      title: "1:1 assessment first",
      body: "Before you join a class, we book you in for a 1:1 with one of our physios. They'll assess your body, your goals and any injuries, then know exactly how to modify each class exercise to suit you.",
    },
    {
      title: "Class format, individual modifications",
      body: "You train alongside a small group, but your physio adjusts each exercise to suit you. Everyone in the room is doing different versions of the work, modified for them. Community of a class, clinical care of a 1:1.",
    },
    {
      title: "Modified as you progress",
      body: "Your physio adjusts your modifications in real time as you get stronger or work through injury. If something's painful or unclear, tell us straight away. That's the whole point of having a physio in the room.",
    },
  ]}
  practitioners={[
    practitioners.brianna,
    practitioners.holly,
    practitioners.steph,
    practitioners.joe,
  ]}
  locations={["Currimundi", "Sandstone Point"]}
  bookingHeading="Two clinics, one rehab-led approach."
  bookingBlurb="Easiest way to start is a 1:1 assessment. We'll work out where your body's at, then match you to the class day, time and clinic that fits your week."
  faqs={[
    {
      q: "What's the difference between the two clinics?",
      a: "Both clinics offer mat, reformer and wundachair work. The only difference is class size, Currimundi caps at 4 per class, Sandstone Point caps at 6. The clinical model is the same at both. Every class is physio-led, every patient is assessed first, and every exercise is modified to the individual.",
    },
    {
      q: "Do I have to do an assessment before joining a class?",
      a: "Yes. The 1:1 assessment is what makes the class actually clinical. Your physio takes a full history, screens any injuries, and works out exactly how to modify each class exercise for you. Without it, we'd be guessing.",
    },
    {
      q: "How do I pay for classes?",
      a: "After your 1:1 assessment, you purchase a class package: 3, 6, 12 or 24 classes. The bigger the pack, the lower the per-class price.",
    },
    {
      q: "What's your cancellation policy?",
      a: "We have a strict 24-hour cancellation policy for classes. If less than 24 hours' notice is given, your class is billed from your package. We'll always send a reminder in advance so you have time to reschedule.",
    },
    {
      q: "Will the class be the same exercises every week?",
      a: "No. Your physio modifies your version of each exercise as you progress, settle into the work, or move through a niggle. Different bodies in the room are doing different versions of the same exercise.",
    },
    {
      q: "Can I claim pilates through my health fund?",
      a: "Yes. Clinical pilates is delivered by a physiotherapist, so it's claimable under physio cover. We're HCF preferred and Medibank preferred for physio. HICAPS available for everyone else.",
    },
    {
      q: "How many sessions per week?",
      a: "Most clients do 1-2 sessions a week. Two is where we see the strongest changes in strength and confidence over the first 8-12 weeks.",
    },
    {
      q: "I'm 8 weeks postnatal, can I start?",
      a: "Pop in for a postnatal physio assessment first. If you've had a straightforward recovery, you'll likely be cleared. If you need to build groundwork on diastasis or pelvic floor first, we'll do that and bring you to class when you're ready.",
    },
  ]}
  related={[
    { title: "Pelvic floor physio", href: "/pelvic-floor-physio", blurb: "Postnatal clearance and pelvic floor screening." },
    { title: "Physiotherapy", href: "/physiotherapy", blurb: "Hands-on rehab for what class work alone won't fix." },
    { title: "Running assessments", href: "/running-assessments", blurb: "Strength + running prescribed together." },
  ]}
>
  <!-- Class packages -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Class packages</p>
      <h2>How class pricing works.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        After your initial 1:1 assessment ($135), you attend classes by purchasing a class
        package. Pick the size that suits how often you'll come, the per-class rate drops the
        bigger the pack.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {packages.map((p) => (
        <div class="rounded-2xl border border-sage-100 bg-white p-6">
          <p class="text-sm font-semibold text-charcoal">{p.name}</p>
          <p class="mt-2 font-display text-3xl text-sage-700">{p.price}</p>
          <p class="mt-1 text-sm text-stone">{p.perClass}</p>
        </div>
      ))}
    </div>

    <div class="mt-8 rounded-2xl border border-tan-200 bg-tan-50/60 p-5 lg:p-6">
      <p class="text-xs uppercase tracking-[0.18em] text-tan-700 font-semibold mb-2">Cancellation policy</p>
      <p class="text-sm text-stone leading-relaxed">
        We have a strict 24-hour cancellation policy for classes. If less than 24 hours' notice is
        given, the class is billed from your package. We'll always send a reminder in advance so you
        have time to reschedule.
      </p>
    </div>
  </section>

  <!-- Class timetables -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-16 lg:pb-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Class timetable</p>
      <h2>When classes run.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        Book your 1:1 assessment first, then your physio will help you pick the class times that
        suit. Class places are capped, so the easiest path in is to message reception once you've
        been assessed.
      </p>
    </div>

    <!-- Currimundi weekly grid -->
    <div class="mb-10">
      <h3 class="text-xl text-charcoal mb-4">Clinical pilates class timetable, Currimundi</h3>
      <div class="rounded-2xl border border-sage-100 bg-white overflow-hidden">
        <div class="grid grid-cols-5 divide-x divide-sage-100">
          {days.map((day) => (
            <div class="bg-sage-50 px-4 py-3">
              <p class="text-xs uppercase tracking-[0.14em] text-tan-600 font-semibold">{day}</p>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-5 divide-x divide-sage-100">
          {days.map((day) => (
            <div class="px-4 py-5 min-h-[6rem]">
              {currimundiClasses[day].length === 0 ? (
                <p class="text-xs text-stone/40">—</p>
              ) : (
                <ul class="space-y-3">
                  {currimundiClasses[day].map((slot) => (
                    <li>
                      <p class="text-sm font-semibold text-charcoal">{slot.time}</p>
                      <p class="text-xs text-sage-600">{slot.lead}</p>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- Sandstone Point weekly grid -->
    <div>
      <h3 class="text-xl text-charcoal mb-4">Clinical pilates class timetable, Sandstone Point</h3>
      <div class="rounded-2xl border border-sage-100 bg-white overflow-hidden">
        <div class="grid grid-cols-5 divide-x divide-sage-100">
          {days.map((day) => (
            <div class="bg-sage-50 px-4 py-3">
              <p class="text-xs uppercase tracking-[0.14em] text-tan-600 font-semibold">{day}</p>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-5 divide-x divide-sage-100">
          {days.map((day) => (
            <div class="px-4 py-5 min-h-[6rem]">
              {sandstoneClasses[day].length === 0 ? (
                <p class="text-xs text-stone/40">—</p>
              ) : (
                <ul class="space-y-3">
                  {sandstoneClasses[day].map((slot) => (
                    <li>
                      <p class="text-sm font-semibold text-charcoal">{slot.time}</p>
                      <p class="text-xs text-sage-600">{slot.lead}</p>
                    </li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</ServiceLayout>
