---
import Layout from "../layouts/Layout.astro";
import BookingBlock from "../components/BookingBlock.astro";

const clinics = [
  {
    name: "Currimundi",
    region: "Sunshine Coast",
    address: "Shop 3 / 768 Nicklin Way",
    suburb: "Currimundi QLD 4551",
    parking: "Free on-site",
    note: "Co-located with Currimundi Family Doctors and Andrew Khoury Podiatry.",
  },
  {
    name: "Sandstone Point",
    region: "Moreton Bay",
    address: "Shop 3 / 208 Bestmann Road East",
    suburb: "Sandstone Point QLD 4511",
    parking: "Free on-site",
    note: "Five minutes over the bridge from Bribie Island.",
  },
];

const services = [
  "Physiotherapy",
  "Pelvic floor physio",
  "Paediatric physio",
  "Vertigo & vestibular",
  "Running assessments",
  "Clinical pilates",
  "Home visit physio",
  "Remedial massage",
];

const success = Astro.url.searchParams.get("success") === "true";
---

<Layout
  title="Contact us, Forward Health"
  description="Get in touch with Forward Health, Currimundi (Sunshine Coast) and Sandstone Point (Moreton Bay). Call 0420 522 558, send a referral as a health professional, or book online."
>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12 lg:py-20">
      <div class="max-w-3xl">
        <p class="text-xs lg:text-sm uppercase tracking-[0.18em] text-tan-600 mb-3 lg:mb-4">Get in touch</p>
        <h1 class="text-charcoal">We'd love to hear from you.</h1>
        <p class="mt-5 lg:mt-6 text-base lg:text-lg text-stone leading-relaxed">
          One phone number, one email, covers both clinics. Booking is fastest online; phone is
          best for questions about appointments, GP referrals, NDIS or DVA. Health professionals
          referring a patient — <a href="#referrals" class="text-sage-600 font-semibold hover:underline">jump to the referrals section</a>.
        </p>
      </div>
    </div>
  </section>

  <!-- Phone + email -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-12 lg:py-20">
    <div class="grid md:grid-cols-2 gap-5 lg:gap-8 mb-12 lg:mb-16">
      <div class="p-7 lg:p-10 rounded-3xl bg-white border border-sage-100">
        <p class="text-xs uppercase tracking-[0.18em] text-tan-600">Phone</p>
        <a href="tel:0420522558" class="mt-2 block font-display text-2xl lg:text-3xl text-charcoal hover:text-sage-600 transition-colors">
          0420 522 558
        </a>
        <p class="mt-3 text-sm text-stone leading-relaxed">
          Reception covers both clinics during our normal operating hours. Outside those hours,
          our virtual receptionist <strong class="text-charcoal">Emma</strong> can help with
          almost anything you need, and if she can't sort it she'll pass a message straight on
          to our team.
        </p>
      </div>
      <div class="p-7 lg:p-10 rounded-3xl bg-white border border-sage-100">
        <p class="text-xs uppercase tracking-[0.18em] text-tan-600">Email</p>
        <a href="mailto:hello@fwdhealth.com.au" class="mt-2 block font-display text-2xl lg:text-3xl text-charcoal hover:text-sage-600 transition-colors break-all">
          hello@fwdhealth.com.au
        </a>
        <p class="mt-3 text-sm text-stone">We normally respond to emails within 1-2 business days.</p>
      </div>
    </div>

    <!-- Clinic addresses -->
    <div class="grid md:grid-cols-2 gap-5 lg:gap-8">
      {clinics.map((c) => (
        <div class="p-7 lg:p-10 rounded-3xl bg-cream-50 border border-sage-100">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-600">{c.region}</p>
          <h2 class="mt-2 font-display text-2xl lg:text-3xl text-charcoal">{c.name}</h2>
          <p class="mt-4 text-stone leading-relaxed">
            {c.address}<br />
            {c.suburb}
          </p>
          <dl class="mt-5 text-sm space-y-1.5">
            <div class="flex justify-between gap-6">
              <dt class="text-stone">Parking</dt>
              <dd class="text-charcoal">{c.parking}</dd>
            </div>
          </dl>
          <p class="mt-5 text-sm text-stone">{c.note}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Referrals (for health professionals) -->
  <section id="referrals" class="bg-cream-50 scroll-mt-24">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-12 lg:py-20">
      <div class="max-w-3xl mb-10">
        <p class="text-xs lg:text-sm uppercase tracking-[0.18em] text-tan-600 mb-3 lg:mb-4">For health professionals</p>
        <h2 class="font-display text-charcoal text-3xl lg:text-4xl">Send us a referral.</h2>
        <p class="mt-5 text-base lg:text-lg text-stone leading-relaxed">
          GPs, specialists and allied health colleagues — send a referral through the form below.
          Attach your letter, add a quick note about what you'd like us to address, and we'll get
          back to you and the patient shortly. Referrals land directly at
          <a href="mailto:hello@fwdhealth.com.au" class="text-sage-600 font-semibold hover:underline">hello@fwdhealth.com.au</a>
          and are read by reception and our clinical team.
        </p>
      </div>

      <div class="grid lg:grid-cols-12 gap-8 lg:gap-12">
        <!-- Form -->
        <div class="lg:col-span-7">
          {success ? (
            <div class="rounded-2xl bg-sage-50 border border-sage-200 p-7 lg:p-10">
              <h3 class="text-charcoal font-display text-2xl">Referral received, thank you.</h3>
              <p class="mt-4 text-stone leading-relaxed">
                We've got your message and the attached document. Someone from the team will get in
                touch shortly. If it's urgent, please give us a call on
                <a href="tel:0420522558" class="text-sage-600 font-semibold hover:underline">0420 522 558</a>.
              </p>
              <a
                href="/contact#referrals"
                class="mt-6 inline-flex items-center rounded-full bg-sage-600 px-6 py-3 text-sm font-semibold text-white hover:bg-sage-700 transition-colors"
              >
                Send another referral
              </a>
            </div>
          ) : (
            <form
              name="referral"
              method="POST"
              data-netlify="true"
              data-netlify-honeypot="bot-field"
              enctype="multipart/form-data"
              action="/contact?success=true#referrals"
              class="space-y-5"
            >
              <input type="hidden" name="form-name" value="referral" />
              <p class="hidden">
                <label>Don't fill this out if you're human: <input name="bot-field" /></label>
              </p>

              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label for="ref-name" class="block text-sm font-semibold text-charcoal mb-2">Your name *</label>
                  <input id="ref-name" name="practitioner_name" type="text" required
                    class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200" />
                </div>
                <div>
                  <label for="ref-practice" class="block text-sm font-semibold text-charcoal mb-2">Practice / clinic *</label>
                  <input id="ref-practice" name="practice" type="text" required
                    class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200" />
                </div>
              </div>

              <div class="grid md:grid-cols-2 gap-5">
                <div>
                  <label for="ref-email" class="block text-sm font-semibold text-charcoal mb-2">Your email *</label>
                  <input id="ref-email" name="practitioner_email" type="email" required
                    class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200" />
                </div>
                <div>
                  <label for="ref-phone" class="block text-sm font-semibold text-charcoal mb-2">Phone (optional)</label>
                  <input id="ref-phone" name="practitioner_phone" type="tel"
                    class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200" />
                </div>
              </div>

              <div>
                <label for="ref-service" class="block text-sm font-semibold text-charcoal mb-2">Service requested</label>
                <select id="ref-service" name="service_requested"
                  class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200">
                  <option value="">Not sure / general referral</option>
                  {services.map((s) => <option value={s}>{s}</option>)}
                </select>
              </div>

              <div>
                <label for="ref-subject" class="block text-sm font-semibold text-charcoal mb-2">Subject *</label>
                <input id="ref-subject" name="subject" type="text" required
                  placeholder="e.g. Referral, [patient name] – chronic knee pain"
                  class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200" />
              </div>

              <div>
                <label for="ref-message" class="block text-sm font-semibold text-charcoal mb-2">Message *</label>
                <textarea id="ref-message" name="message" rows="6" required
                  placeholder="Quick summary of what you'd like us to address, any relevant history, urgency, etc."
                  class="w-full rounded-xl border border-sage-200 bg-white px-4 py-3 text-base text-charcoal focus:border-sage-500 focus:outline-none focus:ring-2 focus:ring-sage-200"></textarea>
              </div>

              <div>
                <label for="ref-file" class="block text-sm font-semibold text-charcoal mb-2">
                  Referral document (PDF, DOC, image, optional)
                </label>
                <input id="ref-file" name="referral_document" type="file"
                  accept=".pdf,.doc,.docx,.png,.jpg,.jpeg,.heic"
                  class="w-full text-sm text-stone file:mr-4 file:rounded-full file:border-0 file:bg-sage-100 file:px-5 file:py-2.5 file:text-sm file:font-semibold file:text-sage-700 hover:file:bg-sage-200 transition-colors" />
                <p class="mt-2 text-xs text-stone">Max 10 MB. We accept PDF, Word, and image files.</p>
              </div>

              <div class="flex items-start gap-3 text-sm text-stone">
                <input id="ref-consent" name="patient_consent" type="checkbox" required
                  class="mt-1 rounded border-sage-300 text-sage-600 focus:ring-sage-500" />
                <label for="ref-consent">
                  I confirm the patient has consented to this referral and to their information being shared with Forward Health. *
                </label>
              </div>

              <button type="submit"
                class="inline-flex items-center rounded-full bg-sage-600 px-7 py-3.5 text-base font-semibold text-white hover:bg-sage-700 transition-colors">
                Send referral
              </button>
            </form>
          )}
        </div>

        <!-- Other ways to refer -->
        <aside class="lg:col-span-5">
          <div class="rounded-2xl border border-sage-100 bg-white p-6 lg:p-7">
            <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold mb-4">Prefer another channel?</p>
            <h3 class="font-display text-xl text-charcoal">Send a referral however suits you.</h3>
            <ul class="mt-5 space-y-4 text-sm">
              <li>
                <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold">Email</p>
                <a href="mailto:hello@fwdhealth.com.au" class="mt-1 block font-display text-lg text-charcoal hover:text-sage-600 break-all">hello@fwdhealth.com.au</a>
              </li>
              <li>
                <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold">Phone</p>
                <a href="tel:0420522558" class="mt-1 block font-display text-lg text-charcoal hover:text-sage-600">0420 522 558</a>
              </li>
              <li>
                <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold">Fax</p>
                <p class="mt-1 font-display text-lg text-charcoal">07 5335 1664</p>
              </li>
              <li>
                <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold">Medical Objects</p>
                <p class="mt-1 font-display text-lg text-charcoal">Forward Health Group</p>
                <p class="mt-1 text-xs text-stone leading-relaxed">Search "Forward Health" in your Medical Objects directory for secure messaging.</p>
              </li>
            </ul>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <BookingBlock variant="sage" />
</Layout>
