---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import poster from "../assets/run-club/run-club-poster.jpg";
import allForRun from "../assets/run-club/all-for-run.jpg";

const sessions = [
  {
    name: "Rise N' Grind",
    cadence: "Weekly",
    day: "Tuesdays",
    time: "5:30 am",
    blurb:
      "Coffee, kilometres and the best sunrise in town. Easy 5–8 km depending on who turns up. All paces welcome — we run in groups so no one's alone.",
    icon: "☕",
  },
  {
    name: "Friday Knock Offs",
    cadence: "Monthly",
    day: "Fridays",
    time: "5:30 pm",
    blurb:
      "End-of-week social run + an optional cheeky beverage to follow. Looser pace, more chat, often a different route to keep things interesting.",
    icon: "🍻",
  },
];
---

<Layout
  title="Forward Run Club — Sunshine Coast running community | Forward Health"
  description="Forward Run Club meets at Aurenda Coffee Co, Kings Beach — Rise N' Grind every Tuesday at 5:30am, Friday Knock Offs once a month. Free, all paces welcome. Led by Joe at Forward Health."
>
  <!-- Hero -->
  <section class="bg-cream-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">@fwdrunclub · Kings Beach</p>
        <h1 class="text-charcoal">Forward Run Club.</h1>
        <p class="mt-2 font-display text-2xl lg:text-3xl text-sage-700 italic">
          All for run. Run for all.
        </p>
        <p class="mt-6 text-lg text-stone leading-relaxed max-w-xl">
          A free, easygoing running community on the Sunshine Coast. Tuesday-morning sunrise runs,
          monthly Friday-arvo socials, post-run coffee at <strong>Aurenda Coffee Co</strong> in Kings Beach.
          Beginner pace, marathon pace, walking-and-chatting pace — they all show up.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="https://www.instagram.com/fwdrunclub/"
            target="_blank"
            rel="noopener"
            class="inline-flex items-center rounded-full bg-sage-600 px-7 py-3.5 text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Follow @fwdrunclub
          </a>
          <a
            href="#sessions"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-7 py-3.5 text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            See the schedule
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <Image
          src={poster}
          alt="Forward Run Club poster — corgi mascot in singlet holding a coffee, with run schedule and Aurenda Coffee Co Kings Beach details"
          width={900}
          height={1200}
          class="aspect-[3/4] rounded-3xl object-cover w-full shadow-sm"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Sessions -->
  <section id="sessions" class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">When we run</p>
      <h2>Two sessions, one community.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        We meet at <strong>Aurenda Coffee Co, Kings Beach</strong>. Park nearby, run, and stick around
        for coffee — half the club lingers afterwards.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {sessions.map((s) => (
        <div class="p-8 rounded-2xl bg-white border border-sage-100 hover:border-sage-300 transition-colors">
          <div class="flex items-start justify-between gap-4">
            <div>
              <p class="text-xs uppercase tracking-[0.18em] text-tan-600">{s.cadence}</p>
              <h3 class="font-display text-3xl text-charcoal mt-1">{s.name}</h3>
            </div>
            <span class="text-3xl" aria-hidden="true">{s.icon}</span>
          </div>
          <p class="mt-4 text-charcoal text-lg font-medium">{s.day} · {s.time}</p>
          <p class="mt-3 text-stone leading-relaxed">{s.blurb}</p>
        </div>
      ))}
    </div>

    <p class="mt-10 text-sm text-stone max-w-2xl">
      First-timer? Just turn up. No registration, no membership, no pressure to stay for the whole run.
      We loop back at landmarks so no one gets dropped.
    </p>
  </section>

  <!-- All For Run banner -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-16">
    <div class="rounded-3xl bg-cream-50 border border-tan-200 p-8 lg:p-12 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-5">
        <Image
          src={allForRun}
          alt="Forward Run Club All For Run, Run For All artwork featuring three animal mascots"
          width={800}
          height={800}
          class="aspect-square rounded-2xl object-cover w-full"
        />
      </div>
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Sweat now, sip later</p>
        <h2 class="text-charcoal">Why we started Forward Run Club.</h2>
        <p class="mt-5 text-stone leading-relaxed">
          A run club shouldn't feel like a race. It shouldn't feel like a club, either — gatekeeping,
          memberships, jargon. Forward Run Club is the run we'd want to turn up to ourselves: warm
          welcome, fair pace, decent coffee, no posturing about your splits.
        </p>
        <p class="mt-4 text-stone leading-relaxed">
          If you've been thinking about running again — or running for the first time — this is the
          place to start. The hardest run is the one you almost don't show up to.
        </p>
      </div>
    </div>
  </section>

  <!-- For runners -->
  <section class="bg-sage-700 text-cream-100">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20 grid lg:grid-cols-12 gap-10">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-200 mb-3">When the niggle arrives</p>
        <h2 class="text-cream-50">Run with us. Get assessed by us.</h2>
        <p class="mt-5 text-cream-100/90 leading-relaxed">
          Joe — who leads Run Club — is also a physiotherapist who sees a lot of runners. If something
          starts hurting, you don't have to wait until it sidelines you. Most niggles are easier to fix
          early than late.
        </p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="/running-assessments"
            class="inline-flex items-center rounded-full bg-cream-50 px-7 py-3.5 text-base font-semibold text-sage-700 hover:bg-tan-100 transition-colors"
          >
            Book a running assessment
          </a>
          <a
            href="tel:0420522558"
            class="inline-flex items-center rounded-full border border-cream-50/40 px-7 py-3.5 text-base font-semibold text-cream-50 hover:bg-sage-600 transition-colors"
          >
            Call 0420 522 558
          </a>
        </div>
      </div>
      <div class="lg:col-span-5">
        <ul class="space-y-3 text-cream-100/90">
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-tan-200"></span>
            <span>Video gait analysis to see what your stride is actually doing</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-tan-200"></span>
            <span>Strength program built for runners (not generic gym work)</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-tan-200"></span>
            <span>Return-to-run plans after injury, surgery or having a baby</span>
          </li>
          <li class="flex gap-3">
            <span class="mt-1.5 w-1.5 h-1.5 shrink-0 rounded-full bg-tan-200"></span>
            <span>Marathon and half-marathon prep</span>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Layout>
