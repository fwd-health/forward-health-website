---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import poster from "../assets/run-club/run-club-poster.jpg";
import allForRun from "../assets/run-club/all-for-run.jpg";
import joeAndFraser from "../assets/run-club/joe-and-fraser.jpg";

const sessions = [
  {
    name: "Rise N' Grind",
    cadence: "Weekly",
    day: "Tuesdays",
    time: "5:30 am",
    blurb:
      "Coffee, kilometres and the best sunrise in town. Easy 5 to 8 km depending on who turns up. All paces welcome, we run in groups so no one's alone.",
    icon: "☕",
  },
  {
    name: "Friday Knock Offs",
    cadence: "Monthly",
    day: "Fridays",
    time: "5:30 pm",
    blurb:
      "End-of-week social run plus an optional cheeky beverage to follow. Looser pace, more chat, often a different route to keep things interesting.",
    icon: "🍻",
  },
];
---

<Layout
  title="Forward Run Club, Sunshine Coast running community | Forward Health"
  description="Forward Run Club meets at Aurenda Coffee Co, Kings Beach. Rise N' Grind every Tuesday at 5:30am, Friday Knock Offs once a month. Free, all paces welcome. Led by Joe (and his dog Fraser) at Forward Health."
>
  <div class="rc-section">
    <!-- Hero -->
    <section class="py-16 lg:py-24">
      <div class="max-w-7xl mx-auto px-5 lg:px-8 grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-7">
          <p class="rc-eyebrow">@fwdrunclub · Kings Beach</p>
          <h1 class="mt-4">Forward Run Club.</h1>
          <p class="mt-2 italic" style="font-family: var(--font-display); font-size: clamp(1.5rem, 2.5vw, 2.25rem); color: var(--color-rc-rust); font-weight: 500;">
            All for run. Run for all.
          </p>
          <p class="mt-7 text-lg leading-relaxed max-w-xl" style="color: var(--color-rc-ink);">
            A free, easygoing running community on the Sunshine Coast. Tuesday-morning sunrise runs,
            monthly Friday-arvo socials, post-run coffee at <strong>Aurenda Coffee Co</strong> in Kings Beach.
            Beginner pace, marathon pace, walking-and-chatting pace, they all show up.
          </p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a
              href="https://www.instagram.com/fwdrunclub/"
              target="_blank"
              rel="noopener"
              class="rc-btn-primary inline-flex items-center rounded-full px-7 py-3.5 text-base font-semibold"
            >
              Follow @fwdrunclub
            </a>
            <a
              href="#sessions"
              class="rc-btn-outline inline-flex items-center rounded-full px-7 py-3.5 text-base font-semibold"
            >
              See the schedule
            </a>
          </div>
        </div>

        <div class="lg:col-span-5">
          <Image
            src={poster}
            alt="Forward Run Club poster with corgi mascot in a Forward singlet holding a coffee, with run schedule and Aurenda Coffee Co Kings Beach details"
            width={900}
            height={1200}
            class="aspect-[3/4] rounded-3xl object-cover w-full shadow-sm"
            loading="eager"
          />
        </div>
      </div>
    </section>

    <!-- Meet the co-leaders -->
    <section class="rc-bg-warm py-16 lg:py-20 border-y" style="border-color: var(--color-rc-rule);">
      <div class="max-w-7xl mx-auto px-5 lg:px-8 grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <Image
            src={joeAndFraser}
            alt="Joe (Forward Run Club lead) and Fraser (his border collie and the Run Club mascot) at sunrise on the beach"
            width={900}
            height={1200}
            class="aspect-[3/4] rounded-3xl object-cover w-full max-w-md mx-auto"
          />
        </div>
        <div class="lg:col-span-7">
          <p class="rc-eyebrow">Meet your co-leaders</p>
          <h2 class="mt-3">Joe and <em style="font-style: italic; color: var(--color-rc-rust);">Fraser</em>.</h2>
          <p class="mt-5 leading-relaxed" style="color: var(--color-rc-muted);">
            Joe is the human leader. Physio by day, runner by every other waking hour, coach of every
            pace from couch-to-5k to marathon. He's also a vestibular and sports physio at Forward Health,
            so if your run hurts in a way it shouldn't, he's a five-minute walk from a treatment table.
          </p>
          <p class="mt-4 leading-relaxed" style="color: var(--color-rc-muted);">
            Fraser is the mascot, the co-leader, and the better-looking half. He's a border collie with
            the world's friendliest face, a soft spot for post-run cuddles, and a strict pace policy of
            'whatever's fun today'. He's also always at run club at least 10 minutes early so he can
            'take care of business', though it never quite stops him having to do it again mid-run.
            (Yes, he's the inspiration for our cartoon mascot.)
          </p>
        </div>
      </div>
    </section>

    <!-- Sessions -->
    <section id="sessions" class="py-16 lg:py-20">
      <div class="max-w-7xl mx-auto px-5 lg:px-8">
        <div class="max-w-2xl mb-12">
          <p class="rc-eyebrow">When we run</p>
          <h2 class="mt-3">Two sessions, one community.</h2>
          <p class="mt-4 leading-relaxed" style="color: var(--color-rc-muted);">
            We meet at <strong>Aurenda Coffee Co, Kings Beach</strong>. Park nearby, run, and stick around
            for coffee (or a beer on Fridays!).
          </p>
          <p class="mt-4 leading-relaxed" style="color: var(--color-rc-muted);">
            Every session is structured to be all-levels-welcome: we head <strong>out for 15 minutes</strong>,
            turn around, and come <strong>back for 15</strong>. Walk, jog, sprint, dance, whatever your
            pace is, we all finish in the same spot. No runner left behind.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-6">
          {sessions.map((s) => (
            <div class="rc-card p-8 transition-colors">
              <div class="flex items-start justify-between gap-4">
                <div>
                  <p class="rc-eyebrow">{s.cadence}</p>
                  <h3 class="mt-1" style="font-family: var(--font-display); font-size: 1.75rem;">{s.name}</h3>
                </div>
                <span class="text-3xl" aria-hidden="true">{s.icon}</span>
              </div>
              <p class="mt-4 text-lg font-medium" style="color: var(--color-rc-ink);">{s.day} · {s.time}</p>
              <p class="mt-3 leading-relaxed" style="color: var(--color-rc-muted);">{s.blurb}</p>
            </div>
          ))}
        </div>

        <p class="mt-10 text-sm max-w-2xl" style="color: var(--color-rc-muted);">
          First-timer? Just turn up. No registration, no membership, no pressure to stay for the whole
          run. We loop back at landmarks so no one gets dropped, and Fraser usually says hello.
        </p>
      </div>
    </section>

    <!-- All For Run banner -->
    <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-16">
      <div class="rc-card p-8 lg:p-12 grid lg:grid-cols-12 gap-10 items-center">
        <div class="lg:col-span-5">
          <Image
            src={allForRun}
            alt="Forward Run Club All For Run, Run For All artwork with three animal mascots holding race medals"
            width={800}
            height={800}
            class="aspect-square rounded-2xl object-cover w-full"
          />
        </div>
        <div class="lg:col-span-7">
          <p class="rc-eyebrow">Sweat now, sip later</p>
          <h2 class="mt-3">Why we started Forward Run Club.</h2>
          <p class="mt-5 leading-relaxed" style="color: var(--color-rc-muted);">
            A run club shouldn't feel like a race. It shouldn't feel like a club, either. No gatekeeping,
            no memberships, no jargon. Forward Run Club is the run we'd want to turn up to ourselves.
            Warm welcome, fair pace, decent coffee, no posturing about your splits.
          </p>
          <p class="mt-4 leading-relaxed" style="color: var(--color-rc-muted);">
            If you've been thinking about running again, or running for the first time, this is the
            place to start. The hardest run is the one you almost don't show up to.
          </p>
        </div>
      </div>
    </section>

    <!-- For runners CTA -->
    <section class="rc-bg-rust" style="color: var(--color-rc-cream);">
      <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20 grid lg:grid-cols-12 gap-10">
        <div class="lg:col-span-7">
          <p class="text-sm uppercase tracking-[0.18em] font-semibold mb-3" style="color: var(--color-rc-tan);">When the niggle arrives</p>
          <h2 style="color: var(--color-rc-cream);">Run with us. Get assessed by us.</h2>
          <p class="mt-5 leading-relaxed" style="color: var(--color-rc-cream); opacity: 0.92;">
            Joe, who leads Run Club, is also a physiotherapist who sees a lot of runners. If something
            starts hurting, you don't have to wait until it sidelines you. Most niggles are easier to
            fix early than late.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a
              href="/running-assessments"
              class="inline-flex items-center rounded-full px-7 py-3.5 text-base font-semibold transition-colors"
              style="background-color: var(--color-rc-cream); color: var(--color-rc-rust-dark);"
            >
              Book a running assessment
            </a>
            <a
              href="tel:0420522558"
              class="inline-flex items-center rounded-full border px-7 py-3.5 text-base font-semibold transition-colors"
              style="border-color: rgba(245,236,215,0.4); color: var(--color-rc-cream);"
            >
              Call 0420 522 558
            </a>
          </div>
        </div>
        <div class="lg:col-span-5">
          <ul class="space-y-3" style="color: var(--color-rc-cream); opacity: 0.92;">
            <li class="flex gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full" style="background-color: var(--color-rc-tan);"></span>
              <span>Video gait analysis to see what your stride is actually doing</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full" style="background-color: var(--color-rc-tan);"></span>
              <span>Strength program built for runners, not generic gym work</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full" style="background-color: var(--color-rc-tan);"></span>
              <span>Return-to-run plans after injury, surgery or having a baby</span>
            </li>
            <li class="flex gap-3">
              <span class="mt-2 w-1.5 h-1.5 shrink-0 rounded-full" style="background-color: var(--color-rc-tan);"></span>
              <span>Marathon and half-marathon prep</span>
            </li>
          </ul>
        </div>
      </div>
    </section>
  </div>
</Layout>

<style is:global>
  .rc-section {
    background-color: var(--color-rc-cream);
    color: var(--color-rc-ink);
  }
  .rc-section h1,
  .rc-section h2,
  .rc-section h3,
  .rc-section h4 {
    font-family: var(--font-display);
    color: var(--color-rc-ink);
    font-weight: 600;
    letter-spacing: -0.01em;
    line-height: 1.1;
  }
  .rc-section h1 {
    font-size: clamp(2.4rem, 5vw, 3.75rem);
  }
  .rc-section h2 {
    font-size: clamp(1.85rem, 3.5vw, 2.65rem);
  }
  .rc-section .rc-eyebrow {
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: 0.78rem;
    color: var(--color-rc-rust-dark);
    font-weight: 600;
  }
  .rc-section .rc-card {
    background: var(--color-rc-warm);
    border: 1px solid var(--color-rc-rule);
    border-radius: 1.25rem;
  }
  .rc-section .rc-btn-primary {
    background-color: var(--color-rc-rust);
    color: var(--color-rc-cream);
    transition: background-color 0.18s ease;
  }
  .rc-section .rc-btn-primary:hover {
    background-color: var(--color-rc-rust-dark);
  }
  .rc-section .rc-btn-outline {
    background: white;
    border: 1px solid var(--color-rc-rule);
    color: var(--color-rc-ink);
    transition: border-color 0.18s ease;
  }
  .rc-section .rc-btn-outline:hover {
    border-color: var(--color-rc-rust);
  }
  .rc-section .rc-bg-warm {
    background-color: var(--color-rc-warm);
  }
  .rc-section .rc-bg-rust {
    background-color: var(--color-rc-rust-dark);
  }
</style>
