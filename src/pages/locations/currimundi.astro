---
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import BookingBlock from "../../components/BookingBlock.astro";
import PractitionerCard from "../../components/PractitionerCard.astro";
import MapEmbed from "../../components/MapEmbed.astro";
import { practitioners } from "../../data/practitioners";
import clinicImage from "../../assets/locations/currimundi.jpg";

const services = [
  { title: "Physiotherapy", href: "/physiotherapy" },
  { title: "Pelvic floor physio", href: "/pelvic-floor-physio" },
  { title: "Remedial massage", href: "/remedial-massage" },
  { title: "Running assessments", href: "/running-assessments" },
  { title: "Vertigo & vestibular physio", href: "/vertigo-vestibular-physio" },
  { title: "Paediatric physio", href: "/paediatric-physio" },
  { title: "Clinical pilates", href: "/clinical-pilates" },
];

const onsitePartners = [
  { name: "Currimundi Family Doctors", role: "GP clinic", href: "https://currimundifamilydoctors.com.au/" },
  { name: "Andrew Khoury Podiatry", role: "Podiatry", href: "https://www.andrewkhourypodiatry.com/" },
  { name: "Sports & Orthopaedic Acupuncture Queensland", role: "Sports & orthopaedic acupuncture", href: "https://www.soaq.au/" },
  { name: "Just See Bee Kinesiology", role: "Kinesiology", href: "https://justseebee.com/" },
];

const team = [
  practitioners.joe,
  practitioners.steph,
  practitioners.brianna,
  practitioners.jarrod,
  practitioners.tara,
  practitioners.carly,
  practitioners.suzie,
  practitioners.erin,
  practitioners.maddie,
];
---

<Layout
  title="Currimundi clinic, Forward Health"
  description="Forward Health Currimundi. Physiotherapy, pelvic floor physio, remedial massage, paediatrics and clinical pilates on the Sunshine Coast. Shop 3 / 768 Nicklin Way, Currimundi QLD 4551."
>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">Sunshine Coast</p>
        <h1 class="text-charcoal">Forward Health Currimundi.</h1>
        <p class="mt-5 text-lg text-stone leading-relaxed max-w-xl">
          Our Sunshine Coast clinic, co-located with Currimundi Family Doctors, Andrew Khoury Podiatry,
          and a small constellation of allied health practitioners. Easy parking, ground-floor access,
          and the largest team across our two locations. Serving Currimundi, Caloundra, Moffat Beach,
          Dicky Beach, Little Mountain, Aroona, Meridan Plains, Warana, Bokarina, Wurtulla, Buddina,
          Battery Hill, Birtinya, Golden Beach, Kings Beach, Shelly Beach and Pelican Waters.
        </p>

        <div class="mt-7 flex flex-wrap gap-3">
          <a
            href="https://forward-health-group.au2.cliniko.com/bookings" target="_blank" rel="noopener"
            class="inline-flex items-center rounded-full bg-sage-600 px-7 py-3.5 text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Book online
          </a>
          <a
            href="tel:0420522558"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-7 py-3.5 text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            Call 0420 522 558
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-3xl bg-white border border-sage-100 p-6 lg:p-8">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-600 mb-3">Find us</p>
          <p class="text-charcoal font-display text-xl leading-snug">
            Shop 3 / 768 Nicklin Way<br />
            Currimundi QLD 4551
          </p>
          <dl class="mt-6 space-y-3 text-sm">
            <div class="flex justify-between gap-6">
              <dt class="text-stone">Phone</dt>
              <dd><a href="tel:0420522558" class="text-charcoal font-medium hover:text-sage-600">0420 522 558</a></dd>
            </div>
            <div class="flex justify-between gap-6">
              <dt class="text-stone">Email</dt>
              <dd><a href="mailto:hello@fwdhealth.com.au" class="text-charcoal font-medium hover:text-sage-600">hello@fwdhealth.com.au</a></dd>
            </div>
            <div class="flex justify-between gap-6">
              <dt class="text-stone">Parking</dt>
              <dd class="text-charcoal text-right">Free on-site</dd>
            </div>
            <div class="flex justify-between gap-6">
              <dt class="text-stone">Access</dt>
              <dd class="text-charcoal text-right">Step-free, ground floor</dd>
            </div>
          </dl>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo + Map -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-12 grid md:grid-cols-2 gap-5">
    <Image
      src={clinicImage}
      alt="Forward Health Currimundi treatment and reformer room"
      width={1200}
      height={800}
      class="aspect-[3/2] rounded-3xl object-cover w-full"
    />
    <MapEmbed
      address="Forward Health, Shop 3 / 768 Nicklin Way, Currimundi QLD 4551"
      title="Forward Health Currimundi, location map"
      aspectClass="aspect-[3/2]"
    />
  </section>

  <!-- Services available -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">What we offer here</p>
      <h2>All our services are available at Currimundi.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        Home visit physiotherapy is also based out of Currimundi. We cover the whole Sunshine Coast and
        northern Moreton Bay regions from here.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {services.map((s) => (
        <a
          href={s.href}
          class="group p-5 rounded-2xl border border-sage-100 bg-white hover:border-sage-300 hover:shadow-sm transition-all"
        >
          <div class="flex items-center justify-between">
            <span class="text-charcoal group-hover:text-sage-600 transition-colors font-medium">{s.title}</span>
            <span class="text-sage-600 group-hover:translate-x-0.5 transition-transform">→</span>
          </div>
          {s.note && <p class="mt-1 text-xs text-tan-600 uppercase tracking-[0.14em]">{s.note}</p>}
        </a>
      ))}
    </div>
  </section>

  <!-- Team at this location -->
  <section class="bg-cream-50 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Practitioners at Currimundi</p>
        <h2>The team you'll meet.</h2>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {team.filter(Boolean).map((p) => (
          <PractitionerCard
            name={p.name}
            role={p.role}
            locations={p.locations}
            blurb={p.blurb}
            href={p.href}
            photo={p.photo}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- On-site partners -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-10">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Allied health on-site</p>
      <h2>One stop for the whole care team.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        Our Currimundi space is shared with practitioners we trust and refer to often. If your physio
        notices something we'd want a podiatrist or GP to look at, you can usually walk next door.
      </p>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {onsitePartners.map((partner) => (
        <a
          href={partner.href}
          target="_blank"
          rel="noopener"
          class="block p-5 rounded-2xl border border-sage-100 bg-white hover:border-sage-300 transition-all"
        >
          <h3 class="text-charcoal text-base">{partner.name}</h3>
          <p class="mt-1 text-xs text-stone">{partner.role}</p>
        </a>
      ))}
    </div>
  </section>

  <BookingBlock
    heading="Book at Currimundi."
    blurb="Book online or give us a call. We usually have new-patient appointments within 1-2 days."
    variant="sage"
  />
</Layout>
