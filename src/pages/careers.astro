---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import BookingBlock from "../components/BookingBlock.astro";

import galleryAnniversary from "../assets/team/gallery/team-clinic-anniversary.png";
import galleryPottery from "../assets/team/gallery/team-pottery-class.png";
import gallerySunset from "../assets/team/gallery/team-sunset-beach.jpg";
import galleryDinner from "../assets/team/gallery/team-dinner-with-baby.jpg";
import galleryBowling from "../assets/team/gallery/team-bowling-night.jpg";
import galleryPizza from "../assets/team/gallery/team-pizza-night.jpg";

const reasons = [
  {
    title: "Real clinical autonomy",
    body:
      "60-minute initial assessments. Follow-ups long enough to do good work. We trust our clinicians to treat the way they were trained — not the way a 15-minute slot demands.",
  },
  {
    title: "Niche development supported",
    body:
      "Want to deepen your skills in pelvic floor, vestibular, paediatrics, sports? We back our team with mentorship, course funding and dedicated case-review time.",
  },
  {
    title: "A team that actually shares notes",
    body:
      "Weekly clinical meetings where we cross-refer cases and learn from each other. Every practitioner has a niche, which means we lean on each other constantly — and the bar of conversation lifts everyone.",
  },
  {
    title: "Sustainable hours",
    body:
      "Saturday rotations are shared. After-hours and weekend coverage is opt-in, not assumed. We want clinicians who'll still be doing this in ten years.",
  },
  {
    title: "Off-the-clock matters too",
    body:
      "Pottery classes, sunset team trips, pizza nights, bowling, and the very occasional Friday Knock Off run. The team that hangs out together gives the best clinical care together — we genuinely believe that.",
  },
  {
    title: "Locally owned, not a chain",
    body:
      "Decisions get made by people who treat patients in this clinic, not a head office in another state. If something needs to change, we can change it next week.",
  },
];

const galleryRow = [galleryDinner, galleryPottery, gallerySunset, galleryBowling, galleryPizza];
---

<Layout
  title="Careers — Forward Health"
  description="Working at Forward Health — physiotherapy, remedial massage, pilates and reception roles across our Currimundi and Sandstone Point clinics. We're always looking for the next great clinician to join the team."
>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-24 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-4">Careers at Forward Health</p>
        <h1 class="text-charcoal">We're always on the lookout for the next great person to join us.</h1>
        <p class="mt-6 text-lg text-stone leading-relaxed max-w-xl">
          Forward Health is a locally-owned physiotherapy and allied health practice across the Sunshine Coast
          and Moreton Bay. We don't always have a specific role advertised — but if you're a clinician (or
          someone front-of-house) who'd genuinely fit our team, we'd love to hear from you. The best people
          we've hired came to us before we were looking.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a
            href="mailto:management@fwdhealth.com.au?subject=Career%20enquiry%20%E2%80%94%20Forward%20Health&body=Hi%20Joe%20and%20Steph%2C%0A%0A"
            class="inline-flex items-center rounded-full bg-sage-600 px-7 py-3.5 text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Send us your CV
          </a>
          <a
            href="#how-to-apply"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-7 py-3.5 text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            See how to apply
          </a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <Image
          src={galleryAnniversary}
          alt="Forward Health team celebrating the clinic's two-year anniversary"
          width={1200}
          height={900}
          class="aspect-[4/3] rounded-3xl object-cover w-full shadow-sm"
          loading="eager"
        />
      </div>
    </div>
  </section>

  <!-- Why us -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Why our team stays</p>
      <h2>What's different about working here.</h2>
      <p class="mt-4 text-stone leading-relaxed">
        We're trying to build the clinic our team would happily stay at for ten years — not five years
        of grind, not the kind of place you tolerate until you can buy your own. Here's what that
        translates to in practice.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {reasons.map((r) => (
        <div class="p-7 rounded-2xl border border-sage-100 bg-white">
          <h3 class="font-display text-xl text-charcoal">{r.title}</h3>
          <p class="mt-3 text-stone leading-relaxed">{r.body}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Off the clock gallery -->
  <section class="bg-cream-50 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-10">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Off the clock</p>
        <h2>This is what a normal week here looks like.</h2>
        <p class="mt-4 text-stone leading-relaxed">
          We work hard during clinic hours. We don't work weekends. And we genuinely like spending
          time together outside the four walls.
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 lg:gap-4">
        {galleryRow.map((img) => (
          <Image
            src={img}
            alt="Forward Health team out together"
            width={600}
            height={450}
            class="aspect-square rounded-2xl object-cover w-full"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Roles we're interested in -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-10">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Roles we're always interested in</p>
      <h2>Who we'd love to hear from.</h2>
    </div>
    <div class="grid md:grid-cols-2 gap-5">
      <div class="p-7 rounded-2xl border border-sage-100 bg-white">
        <h3 class="font-display text-xl text-charcoal">Physiotherapists</h3>
        <p class="mt-3 text-stone leading-relaxed">
          New graduates with serious mentorship needs through to experienced clinicians with a niche
          we'd love to bring in-house — vestibular, women's health, paediatrics, running, OA rehab,
          or general musculoskeletal. We're location-flexible across Currimundi and Sandstone Point.
        </p>
      </div>
      <div class="p-7 rounded-2xl border border-sage-100 bg-white">
        <h3 class="font-display text-xl text-charcoal">Remedial Massage Therapists & Myotherapists</h3>
        <p class="mt-3 text-stone leading-relaxed">
          Diploma-trained remedial therapists or advanced myotherapists — particularly if you can
          cover evenings or weekends at Sandstone Point.
        </p>
      </div>
      <div class="p-7 rounded-2xl border border-sage-100 bg-white">
        <h3 class="font-display text-xl text-charcoal">Clinical Pilates instructors</h3>
        <p class="mt-3 text-stone leading-relaxed">
          Already working in physio or movement and looking to lead reformer-based clinical pilates
          classes? We're capped at 6 per class and physio-led, so the bar is high.
        </p>
      </div>
      <div class="p-7 rounded-2xl border border-sage-100 bg-white">
        <h3 class="font-display text-xl text-charcoal">Client Care Coordinators</h3>
        <p class="mt-3 text-stone leading-relaxed">
          The reception team is the heartbeat of the clinic — calm under pressure, warm with patients,
          good at the small administrative details that keep a clinic running on time.
        </p>
      </div>
    </div>
  </section>

  <!-- How to apply -->
  <section id="how-to-apply" class="bg-sage-700 text-cream-100">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20 grid lg:grid-cols-12 gap-10 items-center">
      <div class="lg:col-span-7">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-200 mb-4">How to apply</p>
        <h2 class="text-cream-50">Send us a note and your CV.</h2>
        <p class="mt-5 text-cream-100/90 leading-relaxed max-w-xl">
          We read every application personally — there's no recruiter in the middle. Send a short
          cover letter (a paragraph or two is plenty) and your CV to:
        </p>

        <div class="mt-7 rounded-2xl bg-sage-600/40 border border-sage-500/40 p-7">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-200 mb-2">Attention</p>
          <p class="font-display text-2xl text-cream-50">Joe Vos & Steph Pyle</p>
          <p class="text-cream-100/80 text-sm mt-1">Co-owners / Directors</p>
          <a
            href="mailto:management@fwdhealth.com.au?subject=Career%20enquiry%20%E2%80%94%20Forward%20Health&body=Hi%20Joe%20and%20Steph%2C%0A%0A"
            class="mt-5 inline-flex items-center rounded-full bg-cream-50 px-7 py-3.5 text-base font-semibold text-sage-700 hover:bg-tan-100 transition-colors"
          >
            management@fwdhealth.com.au
          </a>
        </div>

        <p class="mt-6 text-cream-100/80 text-sm leading-relaxed max-w-xl">
          Tell us what you're looking for in your next role, what kind of practice you want to build,
          and what drew you to Forward Health in particular. We'll get back to you personally within
          a few business days.
        </p>
      </div>

      <div class="lg:col-span-5">
        <div class="rounded-3xl bg-sage-600/30 border border-sage-500/40 p-8">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-200 mb-4">A note from us</p>
          <p class="text-cream-100/90 leading-relaxed italic">
            "We're building something we want to be part of for the long haul — a clinic where the
            clinical work is genuinely great, where the team likes each other, and where the patients
            feel it. If that sounds like the kind of place you'd want to work, send us a note. Even
            if we don't have an open role right now, we'd love to know you exist."
          </p>
          <p class="mt-5 text-cream-100/70 text-sm">— Joe & Steph</p>
        </div>
      </div>
    </div>
  </section>
</Layout>
