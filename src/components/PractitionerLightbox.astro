---
import { Image } from "astro:assets";
import type { Practitioner } from "../data/practitioners";

interface Props {
  practitioner: Practitioner;
}

const { practitioner: p } = Astro.props;

const slugify = (name: string) =>
  name.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");

const lightboxId = `lb-${slugify(p.name)}`;

function parseRole(role: string) {
  const lines = role.split("\n").map((line) => {
    const parts = line.split(" · ");
    return { title: parts[0], status: parts.slice(1).join(" · ") };
  });
  const status = lines.map((l) => l.status).filter(Boolean)[0] ?? "";
  return { lines, status };
}

const r = parseRole(p.role);
---

<dialog
  id={lightboxId}
  class="fh-practitioner-lightbox fixed inset-0 m-auto p-0 max-w-3xl w-[calc(100%-2rem)] max-h-[90vh] bg-cream-50 rounded-3xl border border-sage-100 shadow-2xl backdrop:bg-charcoal/60 backdrop:backdrop-blur-sm"
>
  <div class="overflow-y-auto max-h-[90vh]">
    <div class="relative">
      <button
        type="button"
        data-lightbox-close
        aria-label="Close"
        class="absolute top-4 right-4 z-10 w-10 h-10 rounded-full bg-white/90 backdrop-blur border border-sage-100 hover:bg-white text-charcoal flex items-center justify-center text-xl"
      >
        ×
      </button>
      {p.personalPhotos && p.personalPhotos.length > 0 ? (
        <div class="bg-sage-100 grid grid-cols-3 gap-1 p-1">
          {p.personalPhotos.map((photo, i) => (
            <div class="aspect-square overflow-hidden rounded-sm bg-sage-200">
              <Image
                src={photo}
                alt={`${p.name}, photo ${i + 1}`}
                width={600}
                height={600}
                class="w-full h-full object-cover"
              />
            </div>
          ))}
        </div>
      ) : (
        <div class="aspect-[4/3] bg-sage-100">
          <Image
            src={p.photo}
            alt={p.name}
            width={800}
            height={600}
            class="w-full h-full object-cover"
          />
        </div>
      )}
    </div>
    <div class="p-8 lg:p-10">
      <div>
        <div class="space-y-1">
          {r.lines.map((l) => (
            <p class="text-xs uppercase tracking-[0.18em] text-tan-600 font-semibold flex items-baseline gap-2">
              <span class="w-1 h-1 rounded-full bg-tan-400 shrink-0"></span>
              <span>{l.title}</span>
            </p>
          ))}
        </div>
        {r.status && (
          <p class="mt-3 text-xs italic text-stone">{r.status}</p>
        )}
      </div>
      <h3 class="mt-2 font-display text-3xl text-charcoal">{p.name}</h3>
      <p class="mt-1 text-sm text-stone">{p.locations}</p>

      <div class="mt-6 space-y-4 text-stone leading-relaxed">
        {p.fullBio.split("\n\n").map((para) => (
          <p>{para}</p>
        ))}
      </div>

      {p.specialties.length > 0 && (
        <div class="mt-7">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-600 mb-3">Clinical interests</p>
          <div class="flex flex-wrap gap-2">
            {p.specialties.map((s) => (
              <span class="inline-flex items-center rounded-full bg-sage-100 border border-sage-200 px-3 py-1 text-xs text-sage-700">
                {s}
              </span>
            ))}
          </div>
        </div>
      )}

      {p.qualifications.length > 0 && (
        <div class="mt-6">
          <p class="text-xs uppercase tracking-[0.18em] text-tan-600 mb-3">Qualifications</p>
          <ul class="space-y-1 text-sm text-stone">
            {p.qualifications.map((q) => (
              <li class="flex gap-2.5">
                <span class="mt-2 w-1 h-1 shrink-0 rounded-full bg-sage-500"></span>
                <span>{q}</span>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="mt-8 pt-6 border-t border-sage-100 flex flex-wrap gap-3">
        <a
          href="https://forward-health-group.au2.cliniko.com/bookings" target="_blank" rel="noopener"
          class="inline-flex items-center rounded-full bg-sage-600 px-6 py-3 text-sm font-semibold text-white hover:bg-sage-700 transition-colors"
        >
          Book with {p.name.split(" ")[0]}
        </a>
        <button
          type="button"
          data-lightbox-close
          class="inline-flex items-center rounded-full bg-white border border-sage-200 px-6 py-3 text-sm font-semibold text-charcoal hover:border-sage-400 transition-colors"
        >
          Close
        </button>
      </div>
    </div>
  </div>
</dialog>

<script>
  // Single global click handler — only registered once even if the component renders many times,
  // because Astro deduplicates module-level scripts.
  if (!(window as any).__fhPractitionerLightboxInit) {
    (window as any).__fhPractitionerLightboxInit = true;

    document.addEventListener("click", (e) => {
      const target = e.target as HTMLElement;
      if (!target) return;

      const trigger = target.closest("[data-lightbox-trigger]");
      if (trigger) {
        const id = trigger.getAttribute("data-lightbox-trigger");
        if (id) {
          const dialog = document.getElementById(id) as HTMLDialogElement | null;
          dialog?.showModal();
        }
        return;
      }

      const close = target.closest("[data-lightbox-close]");
      if (close) {
        const dialog = close.closest("dialog") as HTMLDialogElement | null;
        dialog?.close();
        return;
      }

      // Click on the backdrop (the dialog element itself, not its children)
      if (target.tagName === "DIALOG" && target.classList.contains("fh-practitioner-lightbox")) {
        (target as HTMLDialogElement).close();
      }
    });
  }
</script>

<style is:global>
  dialog.fh-practitioner-lightbox[open] {
    animation: fhPractFadeIn 0.18s ease-out;
  }
  dialog.fh-practitioner-lightbox[open]::backdrop {
    animation: fhPractBackdropFadeIn 0.18s ease-out;
  }
  @keyframes fhPractFadeIn {
    from { opacity: 0; transform: scale(0.96); }
    to { opacity: 1; transform: scale(1); }
  }
  @keyframes fhPractBackdropFadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  body:has(dialog.fh-practitioner-lightbox[open]) {
    overflow: hidden;
  }
</style>
