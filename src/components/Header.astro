---
const nav = [
  { label: "Services", href: "/services" },
  { label: "Our team", href: "/team" },
  { label: "Locations", href: "/locations" },
  { label: "Mums & Bubs", href: "/mums-and-bubs" },
  { label: "Run Club", href: "/run-club" },
  { label: "Contact", href: "/contact" },
];
---

<header class="sticky top-0 z-40 bg-white/90 backdrop-blur border-b border-sage-100">
  <div class="max-w-7xl mx-auto px-5 lg:px-8 h-16 flex items-center justify-between gap-6">
    <a href="/" class="flex items-baseline gap-1.5 leading-none">
      <span class="font-display text-2xl font-bold tracking-tight text-sage-600">forward</span>
      <span class="font-body text-sm uppercase tracking-[0.18em] text-tan-600">health</span>
    </a>

    <nav class="hidden lg:flex items-center gap-7 text-sm font-medium text-charcoal">
      {nav.map((item) => (
        <a
          href={item.href}
          class="hover:text-sage-600 transition-colors"
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a
        href="tel:0420522558"
        class="hidden sm:inline-flex items-center text-sm font-medium text-charcoal hover:text-sage-600 transition-colors"
      >
        0420 522 558
      </a>
      <a
        href="#book"
        class="inline-flex items-center justify-center rounded-full bg-sage-600 px-5 py-2.5 text-sm font-semibold text-white hover:bg-sage-700 transition-colors"
      >
        Book online
      </a>
    </div>
  </div>
</header>
