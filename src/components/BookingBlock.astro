---
interface Props {
  heading?: string;
  headingHref?: string;
  blurb?: string;
  variant?: "light" | "sage";
}
const {
  heading = "Ready to book?",
  headingHref,
  blurb = "Book online now, or give us a call. We usually have appointments within 1-2 days.",
  variant = "light",
} = Astro.props;

const isSage = variant === "sage";

// Single source of truth for the booking destination.
const BOOKING_URL = "https://forward-health-group.au2.cliniko.com/bookings";
---

<section
  id="book"
  class:list={[
    "py-16 lg:py-20",
    isSage ? "bg-sage-700 text-cream-100" : "bg-cream-50",
  ]}
>
  <div class="max-w-3xl mx-auto px-5 lg:px-8 text-center">
    <h2 class:list={[isSage ? "text-cream-50" : "text-charcoal"]}>
      {headingHref ? (
        <a href={headingHref} class="underline decoration-2 underline-offset-4 decoration-tan-300 hover:decoration-tan-100 transition-colors">{heading}</a>
      ) : heading}
    </h2>
    <p
      class:list={[
        "mt-5 leading-relaxed",
        isSage ? "text-cream-100/90" : "text-stone",
      ]}
    >
      {blurb}
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a
        href={BOOKING_URL}
        target="_blank"
        rel="noopener"
        class:list={[
          "inline-flex items-center rounded-full px-7 py-3.5 text-base font-semibold transition-colors",
          isSage
            ? "bg-cream-50 text-sage-700 hover:bg-tan-100"
            : "bg-sage-600 text-white hover:bg-sage-700",
        ]}
      >
        Book online ↗
      </a>
      <a
        href="tel:0420522558"
        class:list={[
          "inline-flex items-center rounded-full border px-7 py-3.5 text-base font-semibold transition-colors",
          isSage
            ? "border-cream-50/40 text-cream-50 hover:bg-sage-600"
            : "border-sage-200 bg-white text-charcoal hover:border-sage-400",
        ]}
      >
        Call 0420 522 558
      </a>
    </div>
    <p
      class:list={[
        "mt-5 text-xs",
        isSage ? "text-cream-100/70" : "text-stone/70",
      ]}
    >
      Booking opens in a new tab on Cliniko, our secure booking system.
    </p>
  </div>
</section>
