---
import { Image } from "astro:assets";
import Layout from "./Layout.astro";
import BookingBlock from "../components/BookingBlock.astro";
import PractitionerCard from "../components/PractitionerCard.astro";
import type { ImageMetadata } from "astro";

interface Practitioner {
  name: string;
  role: string;
  locations: string;
  blurb: string;
  href?: string;
  photo?: ImageMetadata;
}

interface FAQ {
  q: string;
  a: string;
}

interface RelatedService {
  title: string;
  href: string;
  blurb: string;
}

interface Props {
  title: string;
  description: string;
  eyebrow: string;
  intro: string;
  heroImage?: ImageMetadata;
  heroImageAlt?: string;
  conditions: { heading: string; items: string[] }[];
  whatToExpect: { title: string; body: string }[];
  practitioners: Practitioner[];
  locations: ("Currimundi" | "Sandstone Point")[];
  faqs: FAQ[];
  related: RelatedService[];
  bookingHeading?: string;
  bookingHeadingHref?: string;
  bookingBlurb?: string;
}

const {
  title,
  description,
  eyebrow,
  intro,
  heroImage,
  heroImageAlt,
  conditions,
  whatToExpect,
  practitioners,
  locations,
  faqs,
  related,
  bookingHeading,
  bookingHeadingHref,
  bookingBlurb,
} = Astro.props;
---

<Layout title={`${title} | Forward Health`} description={description}>
  <!-- Hero -->
  <section class="bg-sage-50">
    <div class="max-w-7xl mx-auto px-5 lg:px-8 py-10 lg:py-20">
      <!-- Eyebrow + heading on the left, image on the right (side-by-side on every breakpoint) -->
      <div class="grid grid-cols-12 gap-3 lg:gap-10 items-center">
        <div class="col-span-5 lg:col-span-7">
          <p class="text-[0.65rem] sm:text-xs lg:text-sm uppercase tracking-[0.14em] lg:tracking-[0.18em] text-tan-600 mb-2 lg:mb-4 leading-tight">{eyebrow}</p>
          <h1 class="text-charcoal" style="font-size: clamp(1.4rem, 5.5vw, 3.75rem); line-height: 1.05;">{title}</h1>
        </div>

        <div class="col-span-7 lg:col-span-5">
          {heroImage ? (
            <Image
              src={heroImage}
              alt={heroImageAlt ?? title}
              width={900}
              height={1125}
              class="aspect-[3/4] lg:aspect-[4/5] rounded-2xl lg:rounded-3xl object-cover w-full"
              loading="eager"
            />
          ) : (
            <div class="aspect-[3/4] lg:aspect-[4/5] rounded-2xl lg:rounded-3xl bg-sage-200/60 border border-sage-200 flex items-center justify-center text-sage-600/60 text-sm">
              [ {title.toLowerCase()} imagery ]
            </div>
          )}
        </div>
      </div>

      <!-- Intro + CTAs + location pills full-width below -->
      <div class="mt-6 lg:mt-8 lg:max-w-2xl">
        <p class="text-base lg:text-lg text-stone leading-relaxed">{intro}</p>
        <div class="mt-5 lg:mt-7 flex flex-wrap gap-3">
          <a
            href="#book"
            class="inline-flex items-center rounded-full bg-sage-600 px-6 lg:px-7 py-3 lg:py-3.5 text-sm lg:text-base font-semibold text-white hover:bg-sage-700 transition-colors"
          >
            Book online
          </a>
          <a
            href="tel:0420522558"
            class="inline-flex items-center rounded-full bg-white border border-sage-200 px-6 lg:px-7 py-3 lg:py-3.5 text-sm lg:text-base font-semibold text-charcoal hover:border-sage-400 transition-colors"
          >
            Call 0420 522 558
          </a>
        </div>

        <div class="mt-6 lg:mt-8 flex flex-wrap gap-2 text-xs">
          {locations.map((loc) => (
            <span class="inline-flex items-center rounded-full bg-white border border-sage-200 px-3 py-1 text-stone">
              <span class="w-1.5 h-1.5 rounded-full bg-sage-500 mr-2"></span>
              Available at {loc}
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Conditions / who this helps -->
  <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
    <div class="max-w-2xl mb-12">
      <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Who we help</p>
      <h2>Conditions and concerns we treat.</h2>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {conditions.map((group) => (
        <div>
          <h3 class="text-lg text-charcoal mb-4">{group.heading}</h3>
          <ul class="space-y-2 text-sm text-stone leading-relaxed">
            {group.items.map((item) => (
              <li class="flex gap-2.5">
                <span class="mt-2 w-1 h-1 shrink-0 rounded-full bg-sage-500"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- What to expect -->
  <section class="bg-cream-50 py-16 lg:py-20">
    <div class="max-w-7xl mx-auto px-5 lg:px-8">
      <div class="max-w-2xl mb-12">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">What to expect</p>
        <h2>Your first appointment.</h2>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {whatToExpect.map((step, i) => (
          <div class="p-7 rounded-2xl bg-white border border-sage-100">
            <div class="text-sage-600 font-display text-3xl">{String(i + 1).padStart(2, "0")}</div>
            <h3 class="mt-3 text-lg text-charcoal">{step.title}</h3>
            <p class="mt-3 text-sm text-stone leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Practitioners -->
  {practitioners.filter(Boolean).length > 0 && (
    <section class="max-w-7xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
      <div class="max-w-2xl mb-12">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Who you'll see</p>
        <h2>Practitioners with this niche.</h2>
        <p class="mt-4 text-stone leading-relaxed">
          We match you to the clinician whose interests fit your condition.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
        {practitioners.filter(Boolean).map((p) => (
          <PractitionerCard
            name={p.name}
            role={p.role}
            locations={p.locations}
            blurb={p.blurb}
            href={p.href}
            photo={p.photo}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Optional custom slot (e.g. class timetables) -->
  <slot />

  <!-- Booking -->
  <BookingBlock heading={bookingHeading} headingHref={bookingHeadingHref} blurb={bookingBlurb} variant="sage" />

  <!-- FAQs -->
  {faqs.length > 0 && (
    <section class="max-w-4xl mx-auto px-5 lg:px-8 py-16 lg:py-20">
      <div class="mb-10">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">FAQs</p>
        <h2>Common questions.</h2>
      </div>
      <div class="divide-y divide-sage-100 border-y border-sage-100">
        {faqs.map((f) => (
          <details class="group py-5">
            <summary class="cursor-pointer list-none flex items-start justify-between gap-6">
              <h3 class="text-lg text-charcoal">{f.q}</h3>
              <span class="text-sage-600 font-display text-2xl group-open:rotate-45 transition-transform shrink-0">+</span>
            </summary>
            <p class="mt-4 text-stone leading-relaxed">{f.a}</p>
          </details>
        ))}
      </div>
    </section>
  )}

  <!-- Related services -->
  {related.length > 0 && (
    <section class="max-w-7xl mx-auto px-5 lg:px-8 pb-20">
      <div class="max-w-2xl mb-10">
        <p class="text-sm uppercase tracking-[0.18em] text-tan-600 mb-3">Related care</p>
        <h2>You might also need...</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {related.map((r) => (
          <a
            href={r.href}
            class="group block p-7 rounded-2xl border border-sage-100 bg-white hover:border-sage-300 hover:shadow-sm transition-all"
          >
            <h3 class="text-charcoal group-hover:text-sage-600 transition-colors">{r.title}</h3>
            <p class="mt-2 text-sm text-stone leading-relaxed">{r.blurb}</p>
            <span class="mt-4 inline-block text-sm font-semibold text-sage-600">Learn more →</span>
          </a>
        ))}
      </div>
    </section>
  )}

  {faqs.length > 0 && (
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: faqs.map((f) => ({
          "@type": "Question",
          name: f.q,
          acceptedAnswer: {
            "@type": "Answer",
            text: f.a,
          },
        })),
      })}
    />
  )}
</Layout>
