---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import AnnouncementPopup from "../components/AnnouncementPopup.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title = "Forward Health. Physiotherapy, Massage & Pilates | Currimundi & Sandstone Point",
  description = "Locally-owned physiotherapy, remedial massage and clinical pilates serving the Sunshine Coast (Currimundi) and Moreton Bay (Sandstone Point / Bribie Island). Specialised care for vertigo, pelvic floor, paediatrics, running injuries and home visits.",
  canonical,
  ogImage = "/og-default.jpg",
} = Astro.props;

const siteUrl = "https://www.fwdhealth.com.au";
const fullCanonical = canonical ?? new URL(Astro.url.pathname, siteUrl).toString();
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:image" content={new URL(ogImage, siteUrl).toString()} />
    <meta property="og:locale" content="en_AU" />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate icon" href="/favicon.ico" />
    <meta name="theme-color" content="#7c8d6f" />

    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "MedicalOrganization",
        name: "Forward Health",
        legalName: "Forward Health Group Pty Ltd",
        url: siteUrl,
        logo: `${siteUrl}/og-default.jpg`,
        telephone: "+61420522558",
        email: "hello@fwdhealth.com.au",
        sameAs: ["https://www.instagram.com/fwdrunclub/"],
        address: [
          {
            "@type": "PostalAddress",
            streetAddress: "Shop 3 / 768 Nicklin Way",
            addressLocality: "Currimundi",
            addressRegion: "QLD",
            postalCode: "4551",
            addressCountry: "AU",
          },
          {
            "@type": "PostalAddress",
            streetAddress: "Shop 3 / 208 Bestmann Road East",
            addressLocality: "Sandstone Point",
            addressRegion: "QLD",
            postalCode: "4511",
            addressCountry: "AU",
          },
        ],
        medicalSpecialty: ["Physiotherapy", "PelvicHealth", "Pediatric"],
      })}
    />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,700&family=Inter:wght@400;500;600;700&display=swap"
    />
  </head>
  <body class="min-h-screen flex flex-col bg-white">
    <!-- Top announcement bar: always-visible careers link -->
    <a
      href="/careers"
      class="block w-full bg-sage-700 text-cream-50 hover:bg-sage-800 transition-colors text-center text-xs sm:text-sm font-medium py-2.5 px-4"
    >
      <span class="hidden sm:inline">Forward Health is growing. </span>We're always looking for great physios, RMTs and client-care coordinators to join the team.
      <span class="ml-2 underline underline-offset-2 decoration-tan-200/60">See careers →</span>
    </a>
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
    <AnnouncementPopup />
  </body>
</html>
