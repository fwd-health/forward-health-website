# Copy this file to .env (which is gitignored) and fill in real values.

# Sanity (after running `sanity init` in ./sanity-studio)
PUBLIC_SANITY_PROJECT_ID=
PUBLIC_SANITY_DATASET=production

# Cliniko booking iframe — already hardcoded in BookingBlock.astro,
# but you can move to env if you want to swap embeds later
# PUBLIC_CLINIKO_EMBED_URL=https://forward-health-group.au2.cliniko.com/bookings?embedded=true

# Plausible / Google Analytics — when you decide on tracking
# PUBLIC_ANALYTICS_DOMAIN=fwdhealth.com.au
